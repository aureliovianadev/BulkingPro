@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <title>BulkingPro - Academia</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            background: #0c0c0c;
            min-height: 100vh;
        }

        .hero {
            min-height: 100vh;
            background: radial-gradient(circle at 25% 40%, rgba(30,30,35,0.4) 0%, transparent 50%),
                        linear-gradient(135deg, #0a0a0a 0%, #121212 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }

        .hero-content {
            max-width: 1200px;
            width: 100%;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: center;
        }

        .info-area h1 {
            font-size: 48px;
            font-weight: 800;
            background: linear-gradient(135deg, #fff 0%, #c4a87a 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 20px;
        }

        .info-area p {
            color: rgba(255,255,255,0.7);
            font-size: 18px;
            line-height: 1.6;
            margin-bottom: 30px;
        }

        .features {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .feature {
            display: flex;
            align-items: center;
            gap: 12px;
            color: rgba(255,255,255,0.6);
            font-size: 14px;
        }

        .feature::before {
            content: "✓";
            color: #ee1920;
            font-weight: bold;
            font-size: 18px;
        }

        .login-card {
            background: rgba(10,10,12,0.9);
            border-radius: 28px;
            padding: 48px 40px;
            width: 100%;
            max-width: 420px;
            margin: 0 auto;
            border: 1px solid rgba(238,25,32,0.4);
            box-shadow: 0 25px 45px -12px rgba(0,0,0,0.6);
        }

        .logo-area {
            text-align: center;
            margin-bottom: 32px;
        }

        .logo-area img {
            height: auto;
            width: 200px;
            max-width: 100%;
            display: inline-block;
        }

        .subtitulo {
            text-align: center;
            color: #c4a87a;
            font-size: 13px;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 32px;
            font-weight: 500;
        }

        .login-form {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .input-group label {
            color: #c4b5a0;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .input-group input {
            background: rgba(20,18,16,0.8);
            border: 1px solid #2a2520;
            border-radius: 14px;
            padding: 14px 18px;
            color: #e8ddd0;
            font-size: 15px;
            transition: all 0.2s;
        }

        .input-group input:focus {
            outline: none;
            border-color: #ee1920;
            background: rgba(28,24,20,0.9);
            box-shadow: 0 0 0 2px rgba(238,25,32,0.2);
        }

        .input-group input::placeholder {
            color: #4a423a;
        }

        .erro-msg {
            background: rgba(238,25,32,0.1);
            border: 1px solid rgba(238,25,32,0.3);
            border-radius: 10px;
            padding: 10px 14px;
            color: #ee1920;
            font-size: 13px;
            text-align: center;
        }

        .btn-login {
            background: linear-gradient(135deg, #ee1920 0%, #c41218 50%, #d9151c 100%);
            color: white;
            border: none;
            border-radius: 40px;
            padding: 14px;
            font-size: 14px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            cursor: pointer;
            margin-top: 8px;
            transition: all 0.25s ease;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 22px rgba(238,25,32,0.5);
        }

        .btn-login:active {
            transform: translateY(1px);
        }

        .links-rodape {
            display: flex;
            justify-content: center;
            gap: 16px;
            margin-top: 28px;
            font-size: 12px;
        }

        .links-rodape a {
            color: #8a7a68;
            text-decoration: none;
            transition: color 0.2s;
        }

        .links-rodape a:hover {
            color: #ee1920;
        }

        @@media (max-width: 900px) {
            .hero-content {
                grid-template-columns: 1fr;
                gap: 40px;
            }
            
            .info-area h1 {
                font-size: 32px;
                text-align: center;
            }
            
            .info-area p {
                text-align: center;
            }
            
            .features {
                align-items: center;
            }
        }
    </style>
</head>

<body>
    <div class="hero">
        <div class="hero-content">
            <div class="info-area">
                <h1>BulkingPro</h1>
                <p>Sua academia inteligente. Treine com os melhores profissionais e acompanhe sua evolução em tempo real.</p>
                <div class="features">
                    <div class="feature">Planos de treino personalizados</div>
                    <div class="feature">Acompanhamento de evolução</div>
                    <div class="feature">Exercícios com vídeos demonstrativos</div>
                    <div class="feature">Suporte 24/7 com seus personais</div>
                </div>
            </div>

            <div class="login-card">
                <div class="logo-area">
                    <img src="~/img/Logo_sem_fundo.png" alt="BulkingPro" />
                </div>

                <p class="subtitulo">ACESSE SUA CONTA</p>

                @if (TempData["ErroLogin"] != null)
                {
                    <div class="erro-msg">@TempData["ErroLogin"]</div>
                }

                <form asp-controller="Account" asp-action="Login" method="post" class="login-form">
                    @Html.AntiForgeryToken()

                    <div class="input-group">
                        <label>E-MAIL</label>
                        <input type="email" name="email" placeholder="seu@email.com" required autofocus />
                    </div>

                    <div class="input-group">
                        <label>SENHA</label>
                        <input type="password" name="senha" placeholder="********" required />
                    </div>

                    <button type="submit" class="btn-login">ENTRAR</button>

                    <div class="links-rodape">
                        <a href="#">Esqueceu a senha?</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>