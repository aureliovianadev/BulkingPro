@model IEnumerable<BulkingPro.Models.Exercicio>
@{
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    ViewData["Title"]      = "Exercícios";
    ViewData["ActivePage"] = "Exercicios";

    var grupos = Model.GroupBy(e => e.GrupoMuscular?.Nome ?? "Outros").OrderBy(g => g.Key);
}

@section Topbar {
    <div class="topbar">
        <div>
            <div class="topbar-title">Exercícios</div>
            <div class="topbar-sub">@Model.Count() exercício(s) cadastrado(s)</div>
        </div>
        <div class="topbar-actions">
            <a class="btn btn-primary" asp-action="Create">
                <i class="ti ti-plus"></i> Novo exercício
            </a>
        </div>
    </div>
}

<div class="search-bar">
    <i class="ti ti-search"></i>
    <input type="text" id="busca" placeholder="Buscar por nome ou grupo muscular..." />
</div>

<div id="exer-container">
    @foreach (var grupo in grupos)
    {
        <div class="grupo-bloco">
            <div class="grupo-titulo">
                <i class="ti ti-circles"></i> @grupo.Key
                <span class="grupo-count">@grupo.Count()</span>
            </div>
            <div class="exer-grid">
                @foreach (var e in grupo)
                {
                    <div class="exer-card">
                        <div class="exer-header">
                            <div class="exer-tag">@(e.GrupoMuscular?.CategoriaMuscular?.Nome ?? "—")</div>
                            @if (e.Ativo)
                            {
                                <span class="dot-ativo" title="Ativo"></span>
                            }
                            else
                            {
                                <span class="dot-inativo" title="Inativo"></span>
                            }
                        </div>
                        <div class="exer-nome">@e.Nome</div>
                        <div class="exer-desc">@(string.IsNullOrWhiteSpace(e.Descricao) ? "Sem descrição." : e.Descricao)</div>
                        <div class="exer-acoes">
                            <a class="btn btn-ghost btn-sm" asp-action="Edit" asp-route-id="@e.Id">
                                <i class="ti ti-edit"></i> Editar
                            </a>
                            <a class="btn btn-ghost btn-sm" asp-action="Details" asp-route-id="@e.Id">
                                <i class="ti ti-eye"></i>
                            </a>
                            <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@e.Id">
                                <i class="ti ti-trash"></i>
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="ti ti-barbell"></i>
            <p>Nenhum exercício cadastrado ainda.</p>
            <a class="btn btn-primary" asp-action="Create">Cadastrar primeiro exercício</a>
        </div>
    }
</div>

<style>
    .grupo-bloco   { margin-bottom: 28px; }
    .grupo-titulo  {
        font-size: 11px; color: rgba(255,255,255,0.3);
        letter-spacing: 1.5px; text-transform: uppercase;
        display: flex; align-items: center; gap: 8px;
        margin-bottom: 12px; padding-bottom: 8px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .grupo-count {
        background: rgba(255,255,255,0.06);
        border-radius: 20px; padding: 1px 9px;
        font-size: 10px; color: rgba(255,255,255,0.35);
    }
    .exer-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 12px;
    }
    .exer-card {
        background: #131316;
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 12px; padding: 16px;
        transition: border-color .2s;
        display: flex; flex-direction: column; gap: 8px;
    }
    .exer-card:hover { border-color: rgba(238,25,32,0.35); }
    .exer-header { display: flex; align-items: center; justify-content: space-between; }
    .exer-tag {
        font-size: 10px; color: #c4a87a;
        letter-spacing: 1px; text-transform: uppercase;
    }
    .dot-ativo, .dot-inativo {
        width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
    }
    .dot-ativo  { background: #2ea043; box-shadow: 0 0 6px rgba(46,160,67,0.5); }
    .dot-inativo{ background: rgba(255,255,255,0.2); }
    .exer-nome  { font-size: 14px; font-weight: 600; color: #fff; }
    .exer-desc  {
        font-size: 12px; color: rgba(255,255,255,0.35);
        line-height: 1.5; flex: 1;
        display: -webkit-box; -webkit-line-clamp: 2;
        -webkit-box-orient: vertical; overflow: hidden;
    }
    .exer-acoes { display: flex; gap: 6px; margin-top: 4px; }

    .empty-state {
        text-align: center; padding: 60px 20px;
        color: rgba(255,255,255,0.3);
    }
    .empty-state i   { font-size: 48px; display: block; margin-bottom: 12px; color: rgba(238,25,32,0.3); }
    .empty-state p   { margin-bottom: 20px; font-size: 14px; }
</style>

<script>
    document.getElementById('busca').addEventListener('input', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('.exer-card').forEach(card => {
            card.style.display = card.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
        // Oculta título do grupo se todos os cards estão ocultos
        document.querySelectorAll('.grupo-bloco').forEach(bloco => {
            const visivel = [...bloco.querySelectorAll('.exer-card')]
                .some(c => c.style.display !== 'none');
            bloco.style.display = visivel ? '' : 'none';
        });
    });
</script>
