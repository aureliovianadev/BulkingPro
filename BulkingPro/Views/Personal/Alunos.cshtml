@model List<BulkingPro.ViewModels.AlunoViewModel>
@{
    Layout = "~/Views/Personal/_PersonalLayout.cshtml";
    ViewData["Title"]      = "Meus Alunos";
    ViewData["ActivePage"] = "Alunos";
}

@section Topbar {
    <div class="topbar">
        <div>
            <div class="topbar-title">Meus Alunos</div>
            <div class="topbar-sub">@Model.Count aluno(s) vinculado(s) a você</div>
        </div>
        <div class="topbar-actions">
            <a class="btn btn-primary" asp-action="CadastrarAluno">
                <i class="ti ti-user-plus"></i> Cadastrar aluno
            </a>
        </div>
    </div>
}

<div class="search-bar" style="display:flex;align-items:center;gap:10px;background:#131316;border:1px solid rgba(255,255,255,.07);border-radius:10px;padding:9px 14px;margin-bottom:16px">
    <i class="ti ti-search" style="color:var(--muted)"></i>
    <input type="text" id="busca" placeholder="Buscar aluno..."
           style="background:none;border:none;outline:none;color:rgba(255,255,255,.75);font-size:13px;flex:1" />
</div>

<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th>Aluno</th>
                <th>E-mail</th>
                <th>Plano ativo</th>
                <th>Status</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody id="tabela-body">
            @{
                var cores = new[] { "r", "g", "b" };
                int i = 0;
            }
            @foreach (var a in Model)
            {
                var cor = cores[i % cores.Length];
                var inics = a.NomeCompleto.Length >= 2
                    ? a.NomeCompleto[0].ToString().ToUpper() + a.NomeCompleto.Split(' ').Last()[0].ToString().ToUpper()
                    : a.NomeCompleto[0].ToString().ToUpper();
                i++;
                <tr>
                    <td>
                        <div class="td-user">
                            <div class="tbl-av @cor">@inics</div>
                            <span class="bold">@a.NomeCompleto</span>
                        </div>
                    </td>
                    <td>@a.Email</td>
                    <td>@(a.NomePlanoAtivo ?? "—")</td>
                    <td>
                        @if (a.Ativo) { <span class="badge badge-active">Ativo</span> }
                        else          { <span class="badge badge-inactive">Inativo</span> }
                    </td>
                    <td style="display:flex;gap:6px;flex-wrap:wrap">
                        <a class="btn btn-ghost btn-sm" asp-action="CriarPlano" asp-route-alunoId="@a.Id">
                            <i class="ti ti-clipboard-plus"></i> Plano
                        </a>
                        <a class="btn btn-ghost btn-sm" asp-action="Medidas" asp-route-alunoId="@a.Id">
                            <i class="ti ti-ruler"></i>
                        </a>
                        <a class="btn btn-ghost btn-sm" asp-action="Anamnese" asp-route-alunoId="@a.Id">
                            <i class="ti ti-clipboard-text"></i>
                        </a>
                        
                        @if (a.Ativo)
                        {
                            <form asp-action="InativarAluno" method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@a.Id" />
                                <button type="submit" class="btn btn-danger btn-sm" 
                                        onclick="return confirm('Inativar @a.NomeCompleto? O aluno não poderá mais acessar o sistema até ser reativado.')">
                                    <i class="ti ti-user-x"></i> Inativar
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="ReativarAluno" method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@a.Id" />
                                <button type="submit" class="btn btn-success btn-sm">
                                    <i class="ti ti-user-check"></i> Reativar
                                </button>
                            </form>
                        }
                        
                        <form asp-action="DesvincularAluno" method="post" style="display:inline"
                              onsubmit="return confirm('Desvincular @a.NomeCompleto? O aluno será removido da sua lista, mas continuará existindo no sistema.')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@a.Id" />
                            <button type="submit" class="btn btn-ghost btn-sm" style="color:var(--gold)">
                                <i class="ti ti-link-off"></i> Desvincular
                            </button>
                        </form>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="5" style="text-align:center;color:var(--muted);padding:28px">Nenhum aluno cadastrado ainda.</td></tr>
            }
        </tbody>
    </table>
</div>

<style>
    .btn-success {
        background: rgba(46,160,67,.15);
        color: #2ea043;
        border: 1px solid rgba(46,160,67,.25);
    }
    .btn-success:hover {
        background: rgba(46,160,67,.25);
    }
</style>

<script>
    document.getElementById('busca').addEventListener('input', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('#tabela-body tr').forEach(tr => {
            tr.style.display = tr.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    });
</script>