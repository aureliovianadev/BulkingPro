@model BulkingPro.ViewModels.ConfiguracoesViewModel
@{
    if (User.IsInRole("Administrador"))
    {
        Layout = "~/Views/Admin/_AdminLayout.cshtml";
        ViewData["ActivePage"] = "Configuracoes";
    }
    else if (User.IsInRole("Moderador"))
    {
        Layout = "~/Views/Personal/_PersonalLayout.cshtml";
        ViewData["ActivePage"] = "Configuracoes";
    }
    else if (User.IsInRole("Usuario"))
    {
        Layout = "~/Views/Aluno/_AlunoLayout.cshtml";
        ViewData["ActivePage"] = "Configuracoes";
    }
    else
    {
        Layout = null;
    }
    ViewData["Title"] = "Minha conta";
}

@section Topbar {
    <div class="topbar">
        <div>
            <div class="topbar-title">Minha conta</div>
            <div class="topbar-sub">Edite suas informações pessoais e segurança</div>
        </div>
    </div>
}

<div style="max-width:600px; margin:0 auto;">

    <!-- Dados pessoais -->
    <div class="card" style="margin-bottom:24px">
        <div class="card-body">
            <div class="card-title" style="display:flex; align-items:center; gap:10px; margin-bottom:20px; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:12px">
                <i class="ti ti-user-circle" style="font-size:24px; color:var(--gold)"></i>
                <span style="font-size:16px; font-weight:600">Dados pessoais</span>
            </div>
            
            <form asp-controller="Account" asp-action="AtualizarNome" method="post">
                @Html.AntiForgeryToken()
                
                <div class="form-group" style="margin-bottom:20px">
                    <label class="form-label" style="display:flex; align-items:center; gap:6px; margin-bottom:8px">
                        <i class="ti ti-user" style="font-size:14px"></i> Nome completo
                    </label>
                    <input class="form-control" asp-for="NomeCompleto" placeholder="Seu nome completo" 
                           style="width:100%; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:12px 16px; color:#fff" />
                    <span asp-validation-for="NomeCompleto" class="field-validation-error"></span>
                </div>
                
                <div class="form-group" style="margin-bottom:24px">
                    <label class="form-label" style="display:flex; align-items:center; gap:6px; margin-bottom:8px">
                        <i class="ti ti-mail" style="font-size:14px"></i> E-mail
                    </label>
                    <input class="form-control" asp-for="Email" type="email" placeholder="seu@email.com"
                           style="width:100%; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:12px 16px; color:#fff" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>
                
                <button type="submit" class="btn btn-primary" style="display:flex; align-items:center; gap:8px; background:linear-gradient(135deg, #ee1920, #c41218); border:none; border-radius:30px; padding:10px 24px; font-weight:600">
                    <i class="ti ti-device-floppy"></i> Salvar alterações
                </button>
            </form>
        </div>
    </div>

    <!-- Alterar senha -->
    <div class="card" style="margin-bottom:24px">
        <div class="card-body">
            <div class="card-title" style="display:flex; align-items:center; gap:10px; margin-bottom:20px; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:12px">
                <i class="ti ti-lock" style="font-size:24px; color:var(--gold)"></i>
                <span style="font-size:16px; font-weight:600">Alterar senha</span>
            </div>
            
            <form asp-controller="Account" asp-action="AlterarSenha" method="post">
                @Html.AntiForgeryToken()
                
                <div class="form-group" style="margin-bottom:20px">
                    <label class="form-label" style="display:flex; align-items:center; gap:6px; margin-bottom:8px">
                        <i class="ti ti-key" style="font-size:14px"></i> Senha atual
                    </label>
                    <input class="form-control" asp-for="SenhaAtual" type="password" placeholder="••••••••"
                           style="width:100%; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:12px 16px; color:#fff" />
                    <span asp-validation-for="SenhaAtual" class="field-validation-error"></span>
                </div>
                
                <div class="form-group" style="margin-bottom:20px">
                    <label class="form-label" style="display:flex; align-items:center; gap:6px; margin-bottom:8px">
                        <i class="ti ti-lock-plus" style="font-size:14px"></i> Nova senha
                    </label>
                    <input class="form-control" asp-for="NovaSenha" type="password" placeholder="Mínimo 6 caracteres"
                           style="width:100%; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:12px 16px; color:#fff" />
                    <span asp-validation-for="NovaSenha" class="field-validation-error"></span>
                </div>
                
                <div class="form-group" style="margin-bottom:24px">
                    <label class="form-label" style="display:flex; align-items:center; gap:6px; margin-bottom:8px">
                        <i class="ti ti-lock-check" style="font-size:14px"></i> Confirmar nova senha
                    </label>
                    <input class="form-control" asp-for="ConfirmarSenha" type="password" placeholder="Repita a nova senha"
                           style="width:100%; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:12px 16px; color:#fff" />
                    <span asp-validation-for="ConfirmarSenha" class="field-validation-error"></span>
                </div>
                
                <button type="submit" class="btn btn-primary" style="display:flex; align-items:center; gap:8px; background:linear-gradient(135deg, #ee1920, #c41218); border:none; border-radius:30px; padding:10px 24px; font-weight:600">
                    <i class="ti ti-lock-check"></i> Alterar senha
                </button>
            </form>
        </div>
    </div>

    <!-- Sair da conta -->
    <div class="card" style="border:1px solid rgba(238,25,32,0.3); background:rgba(238,25,32,0.03)">
        <div class="card-body">
            <div class="card-title" style="display:flex; align-items:center; gap:10px; margin-bottom:16px">
                <i class="ti ti-logout" style="font-size:24px; color:#ee1920"></i>
                <span style="font-size:16px; font-weight:600; color:#ee1920">Sair da conta</span>
            </div>
            
            <p style="font-size:13px; color:var(--muted); margin-bottom:20px; line-height:1.5">
                Encerra sua sessão atual. Você precisará fazer login novamente para acessar o sistema.
            </p>
            
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn" style="display:flex; align-items:center; gap:8px; background:rgba(238,25,32,0.15); border:1px solid rgba(238,25,32,0.3); border-radius:30px; padding:10px 24px; color:#ee1920; font-weight:600; cursor:pointer; transition:all 0.2s">
                    <i class="ti ti-logout"></i> Sair agora
                </button>
            </form>
        </div>
    </div>

</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}