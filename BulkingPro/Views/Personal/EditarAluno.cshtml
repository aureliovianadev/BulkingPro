@model BulkingPro.ViewModels.EditarAlunoViewModel
@{
    Layout = "~/Views/Personal/_PersonalLayout.cshtml";
    ViewData["Title"] = "Editar Aluno";
    ViewData["ActivePage"] = "Alunos";
}

@section Topbar {
    <div class="topbar">
        <div>
            <div class="topbar-title">Editar Aluno</div>
            <div class="topbar-sub">Altere os dados e horários de atendimento</div>
        </div>
        <div class="topbar-actions">
            <a class="btn btn-ghost" asp-action="Alunos"><i class="ti ti-arrow-left"></i> Voltar</a>
        </div>
    </div>
}

<div class="card">
    <div class="card-body">
        <form asp-action="EditarAluno" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <!-- Dados Pessoais -->
            <div class="card-title"><i class="ti ti-user"></i> Dados Pessoais</div>
            <div class="form-row">
                <div class="form-group" style="flex:2">
                    <label class="form-label" asp-for="NomeCompleto">Nome completo</label>
                    <input class="form-control" asp-for="NomeCompleto" />
                    <span asp-validation-for="NomeCompleto" class="field-validation-error"></span>
                </div>
                <div class="form-group" style="flex:1">
                    <label class="form-label" asp-for="Cpf">CPF</label>
                    <input class="form-control" asp-for="Cpf" id="cpf" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group" style="flex:2">
                    <label class="form-label" asp-for="Email">E-mail</label>
                    <input class="form-control" asp-for="Email" type="email" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>
                <div class="form-group" style="flex:1">
                    <label class="form-label" asp-for="Telefone">Telefone (WhatsApp)</label>
                    <input class="form-control" asp-for="Telefone" id="telefone" />
                </div>
            </div>
            <div class="form-group">
                <label class="toggle-label">
                    <input type="checkbox" asp-for="Ativo" class="toggle-input" />
                    <span class="toggle-track"></span>
                    <span class="toggle-text">Aluno ativo</span>
                </label>
            </div>

            <!-- Horários de Atendimento -->
            <div class="card-title" style="margin-top:24px"><i class="ti ti-calendar-clock"></i> Horários de Atendimento</div>
            <p style="font-size:12px;color:var(--muted);margin-bottom:16px">Defina os horários e selecione os dias da semana</p>

            <div id="horarios-container">
                @for (int i = 0; i < Model.HorariosAtendimento.Count; i++)
                {
                    var h = Model.HorariosAtendimento[i];
                    <div class="horario-card" data-index="@i">
                        <div class="horario-header">
                            <div class="form-row" style="align-items:center">
                                <div class="form-group" style="flex:1">
                                    <label class="form-label">Horário início</label>
                                    <input type="time" name="HorariosAtendimento[@i].HoraInicio" class="form-control" value="@(h.HoraInicio.HasValue ? h.HoraInicio.Value.ToString(@"hh\:mm") : "")" />
                                </div>
                                <div class="form-group" style="flex:1">
                                    <label class="form-label">Horário fim</label>
                                    <input type="time" name="HorariosAtendimento[@i].HoraFim" class="form-control" value="@(h.HoraFim.HasValue ? h.HoraFim.Value.ToString(@"hh\:mm") : "")" />
                                </div>
                                <button type="button" class="btn btn-danger btn-sm" onclick="removerHorario(this, @i)">
                                    <i class="ti ti-trash"></i>
                                </button>
                            </div>
                        </div>
                        <div class="horario-dias">
                            <label class="dias-label">Dias da semana:</label>
                            <div class="dias-grid">
                                <label class="dia-checkbox"><input type="checkbox" name="HorariosAtendimento[@i].Domingo" @(h.Domingo ? "checked" : "") /> Dom</label>
                                <label class="dia-checkbox"><input type="checkbox" name="HorariosAtendimento[@i].Segunda" @(h.Segunda ? "checked" : "") /> Seg</label>
                                <label class="dia-checkbox"><input type="checkbox" name="HorariosAtendimento[@i].Terca" @(h.Terca ? "checked" : "") /> Ter</label>
                                <label class="dia-checkbox"><input type="checkbox" name="HorariosAtendimento[@i].Quarta" @(h.Quarta ? "checked" : "") /> Qua</label>
                                <label class="dia-checkbox"><input type="checkbox" name="HorariosAtendimento[@i].Quinta" @(h.Quinta ? "checked" : "") /> Qui</label>
                                <label class="dia-checkbox"><input type="checkbox" name="HorariosAtendimento[@i].Sexta" @(h.Sexta ? "checked" : "") /> Sex</label>
                                <label class="dia-checkbox"><input type="checkbox" name="HorariosAtendimento[@i].Sabado" @(h.Sabado ? "checked" : "") /> Sáb</label>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <button type="button" class="btn btn-ghost btn-sm" onclick="adicionarHorario()" style="margin-top:16px">
                <i class="ti ti-plus"></i> Adicionar outro horário
            </button>

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(""))
            {
                <div class="alert alert-danger" style="margin-top:16px">
                    @foreach (var e in ViewData.ModelState[""]!.Errors) { <div>@e.ErrorMessage</div> }
                </div>
            }

            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:24px">
                <i class="ti ti-device-floppy"></i> Salvar alterações
            </button>
        </form>
    </div>
</div>

<script>
    let horarioIndex = @Model.HorariosAtendimento.Count;

    function adicionarHorario() {
        const container = document.getElementById('horarios-container');
        const newCard = document.createElement('div');
        newCard.className = 'horario-card';
        newCard.setAttribute('data-index', horarioIndex);
        newCard.innerHTML = `
            <div class="horario-header">
                <div class="form-row" style="align-items:center">
                    <div class="form-group" style="flex:1">
                        <label class="form-label">Horário início</label>
                        <input type="time" name="HorariosAtendimento[${horarioIndex}].HoraInicio" class="form-control" />
                    </div>
                    <div class="form-group" style="flex:1">
                        <label class="form-label">Horário fim</label>
                        <input type="time" name="HorariosAtendimento[${horarioIndex}].HoraFim" class="form-control" />
                    </div>
                    <button type="button" class="btn btn-danger btn-sm" onclick="removerHorario(this, ${horarioIndex})">
                        <i class="ti ti-trash"></i>
                    </button>
                </div>
            </div>
            <div class="horario-dias">
                <label class="dias-label">Dias da semana:</label>
                <div class="dias-grid">
                    <label class="dia-checkbox"><input type="checkbox" name="HorariosAtendimento[${horarioIndex}].Domingo" /> Dom</label>
                    <label class="dia-checkbox"><input type="checkbox" name="HorariosAtendimento[${horarioIndex}].Segunda" /> Seg</label>
                    <label class="dia-checkbox"><input type="checkbox" name="HorariosAtendimento[${horarioIndex}].Terca" /> Ter</label>
                    <label class="dia-checkbox"><input type="checkbox" name="HorariosAtendimento[${horarioIndex}].Quarta" /> Qua</label>
                    <label class="dia-checkbox"><input type="checkbox" name="HorariosAtendimento[${horarioIndex}].Quinta" /> Qui</label>
                    <label class="dia-checkbox"><input type="checkbox" name="HorariosAtendimento[${horarioIndex}].Sexta" /> Sex</label>
                    <label class="dia-checkbox"><input type="checkbox" name="HorariosAtendimento[${horarioIndex}].Sabado" /> Sáb</label>
                </div>
            </div>
        `;
        container.appendChild(newCard);
        horarioIndex++;
    }

    function removerHorario(btn, index) {
        btn.closest('.horario-card').remove();
    }

    // Máscara para CPF e Telefone
    document.getElementById('cpf')?.addEventListener('input', function(e) {
        let value = e.target.value.replace(/\D/g, '');
        if (value.length <= 11) {
            value = value.replace(/(\d{3})(\d)/, '$1.$2');
            value = value.replace(/(\d{3})(\d)/, '$1.$2');
            value = value.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
            e.target.value = value;
        }
    });

    document.getElementById('telefone')?.addEventListener('input', function(e) {
        let value = e.target.value.replace(/\D/g, '');
        if (value.length <= 11) {
            value = value.replace(/(\d{2})(\d)/, '($1) $2');
            value = value.replace(/(\d{5})(\d)/, '$1-$2');
            e.target.value = value;
        }
    });
</script>

<style>
    .horario-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 16px;
    }
    .horario-header {
        margin-bottom: 12px;
    }
    .horario-dias {
        border-top: 1px solid rgba(255,255,255,0.06);
        padding-top: 12px;
    }
    .dias-label {
        font-size: 11px;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 10px;
        display: block;
    }
    .dias-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }
    .dia-checkbox {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 12px;
        color: rgba(255,255,255,0.6);
        cursor: pointer;
    }
    .dia-checkbox input {
        width: 16px;
        height: 16px;
        cursor: pointer;
        accent-color: var(--red);
    }
    .toggle-label {
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
    }
    .toggle-input {
        display: none;
    }
    .toggle-track {
        width: 40px;
        height: 22px;
        border-radius: 11px;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.15);
        position: relative;
    }
    .toggle-track::after {
        content: '';
        position: absolute;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: rgba(255,255,255,0.4);
        top: 2px;
        left: 2px;
        transition: all .2s;
    }
    .toggle-input:checked + .toggle-track {
        background: rgba(46,160,67,0.5);
        border-color: #2ea043;
    }
    .toggle-input:checked + .toggle-track::after {
        left: 20px;
        background: #2ea043;
    }
    .toggle-text {
        font-size: 13px;
        color: rgba(255,255,255,0.6);
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}