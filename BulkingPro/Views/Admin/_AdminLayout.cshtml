<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — BulkingPro Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --red:     #ee1920;
            --red-dim: rgba(238,25,32,0.12);
            --gold:    #c4a87a;
            --bg:      #0a0a0a;
            --bg2:     #0e0e10;
            --bg3:     #131316;
            --border:  rgba(255,255,255,0.07);
            --text:    rgba(255,255,255,0.85);
            --muted:   rgba(255,255,255,0.4);
            --faint:   rgba(255,255,255,0.15);
        }

        html, body { height: 100%; font-family: system-ui, -apple-system, 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); font-size: 14px; }

        /* ── Layout ── */
        .admin-wrap { display: flex; height: 100vh; overflow: hidden; }

        /* ── Sidebar ── */
        .sidebar {
            width: 230px; flex-shrink: 0;
            background: var(--bg2);
            border-right: 1px solid var(--border);
            display: flex; flex-direction: column;
        }
        .sidebar-brand {
            padding: 14px 18px;
            border-bottom: 1px solid var(--border);
            display: flex; flex-direction: column; align-items: flex-start; gap: 6px;
        }
        .sidebar-brand img { height: 100px; width: auto; object-fit: contain; }
        .sidebar-brand-role { font-size: 10px; color: var(--red); letter-spacing: 2px; text-transform: uppercase; }

        .sidebar-nav { flex: 1; overflow-y: auto; padding: 8px 0; }
        .sidebar-nav::-webkit-scrollbar { width: 0; }

        .nav-section {
            font-size: 10px; color: rgba(255,255,255,0.22);
            letter-spacing: 1.5px; text-transform: uppercase;
            padding: 14px 18px 5px;
        }
        .nav-link {
            display: flex; align-items: center; gap: 10px;
            padding: 9px 18px;
            color: var(--muted); font-size: 13px;
            text-decoration: none;
            border-left: 2px solid transparent;
            transition: color .15s, background .15s;
        }
        .nav-link i { font-size: 17px; width: 20px; }
        .nav-link:hover { color: rgba(255,255,255,.8); background: rgba(255,255,255,.03); }
        .nav-link.active { color: #fff; background: var(--red-dim); border-left-color: var(--red); }

        .sidebar-footer {
            padding: 14px 18px;
            border-top: 1px solid var(--border);
            display: flex; align-items: center; gap: 10px;
        }
        .avatar {
            width: 34px; height: 34px; border-radius: 50%;
            background: var(--red-dim);
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 600; color: var(--red);
            flex-shrink: 0;
        }
        .avatar-name  { font-size: 12px; color: #fff; font-weight: 500; }
        .avatar-email { font-size: 10px; color: var(--muted); }

        /* ── Main ── */
        .main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

        .topbar {
            padding: 14px 28px;
            border-bottom: 1px solid var(--border);
            background: var(--bg2);
            display: flex; align-items: center; justify-content: space-between;
            flex-shrink: 0;
        }
        .topbar-title { font-size: 16px; font-weight: 600; color: #fff; }
        .topbar-sub   { font-size: 12px; color: var(--muted); margin-top: 2px; }
        .topbar-actions { display: flex; gap: 10px; align-items: center; }

        .content { flex: 1; overflow-y: auto; padding: 24px 28px; }
        .content::-webkit-scrollbar { width: 4px; }
        .content::-webkit-scrollbar-thumb { background: rgba(255,255,255,.1); border-radius: 4px; }

        /* ── Botões ── */
        .btn { display: inline-flex; align-items: center; gap: 6px; border-radius: 20px; padding: 8px 18px; font-size: 12px; font-weight: 500; cursor: pointer; border: none; text-decoration: none; transition: opacity .15s; }
        .btn:hover { opacity: .85; }
        .btn-primary { background: var(--red); color: #fff; }
        .btn-ghost   { background: rgba(255,255,255,.05); color: var(--muted); border: 1px solid var(--border); }
        .btn-danger  { background: rgba(238,25,32,.15); color: var(--red); border: 1px solid rgba(238,25,32,.25); }
        .btn-sm { padding: 5px 12px; font-size: 11px; }

        /* ── Cards ── */
        .card { background: var(--bg3); border: 1px solid var(--border); border-radius: 12px; }
        .card-body { padding: 18px; }

        /* ── Stats grid ── */
        .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 22px; }
        .stat-card { background: var(--bg3); border: 1px solid var(--border); border-radius: 12px; padding: 18px; }
        .stat-icon { width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; margin-bottom: 14px; font-size: 18px; }
        .stat-icon.red   { background: rgba(238,25,32,.15); color: var(--red); }
        .stat-icon.gold  { background: rgba(196,168,122,.15); color: var(--gold); }
        .stat-icon.blue  { background: rgba(56,139,253,.15); color: #388bfd; }
        .stat-icon.green { background: rgba(46,160,67,.15); color: #2ea043; }
        .stat-val   { font-size: 28px; font-weight: 600; color: #fff; line-height: 1; }
        .stat-label { font-size: 11px; color: var(--muted); margin-top: 4px; }

        /* ── Tabela ── */
        .table-wrap { background: var(--bg3); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
        table { width: 100%; border-collapse: collapse; }
        thead th { font-size: 10px; color: rgba(255,255,255,.25); letter-spacing: 1px; text-transform: uppercase; padding: 12px 18px; text-align: left; border-bottom: 1px solid var(--border); font-weight: 400; white-space: nowrap; }
        tbody td { padding: 12px 18px; font-size: 13px; color: rgba(255,255,255,.65); border-bottom: 1px solid rgba(255,255,255,.04); vertical-align: middle; }
        tbody tr:last-child td { border-bottom: none; }
        tbody tr:hover td { background: rgba(255,255,255,.02); }
        td.bold { color: rgba(255,255,255,.9); font-weight: 500; }
        .td-user { display: flex; align-items: center; gap: 10px; }
        .tbl-av { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; flex-shrink: 0; }
        .tbl-av.r { background: rgba(238,25,32,.2);    color: var(--red); }
        .tbl-av.g { background: rgba(196,168,122,.2);  color: var(--gold); }
        .tbl-av.b { background: rgba(56,139,253,.2);   color: #388bfd; }
        .tbl-av.p { background: rgba(120,80,200,.2);   color: #9a70e0; }
        .td-actions { display: flex; gap: 6px; }

        /* ── Badge ── */
        .badge { display: inline-block; font-size: 10px; font-weight: 500; padding: 3px 10px; border-radius: 20px; }
        .badge-active   { background: rgba(46,160,67,.12);   color: #2ea043; border: 1px solid rgba(46,160,67,.2); }
        .badge-inactive { background: rgba(255,255,255,.06); color: var(--muted); border: 1px solid var(--border); }

        /* ── Search ── */
        .search-bar { display: flex; align-items: center; gap: 10px; background: var(--bg3); border: 1px solid var(--border); border-radius: 10px; padding: 9px 14px; margin-bottom: 16px; }
        .search-bar i { color: var(--muted); font-size: 16px; }
        .search-bar input { background: none; border: none; outline: none; color: rgba(255,255,255,.75); font-size: 13px; flex: 1; }
        .search-bar input::placeholder { color: rgba(255,255,255,.2); }

        /* ── Alert ── */
        .alert { padding: 12px 16px; border-radius: 8px; font-size: 13px; margin-bottom: 16px; }
        .alert-success { background: rgba(46,160,67,.12); color: #2ea043; border: 1px solid rgba(46,160,67,.2); }
        .alert-danger  { background: rgba(238,25,32,.12); color: var(--red); border: 1px solid rgba(238,25,32,.25); }

        /* ── Two col ── */
        .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .section-title { font-size: 13px; font-weight: 500; color: rgba(255,255,255,.6); margin-bottom: 12px; }

        /* ── Permissões ── */
        .role-card { background: var(--bg3); border: 1px solid var(--border); border-radius: 12px; padding: 20px; margin-bottom: 12px; }
        .role-header { display: flex; align-items: center; gap: 14px; margin-bottom: 14px; }
        .role-icon { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 20px; }
        .role-title { font-size: 15px; font-weight: 600; color: #fff; }
        .role-desc  { font-size: 12px; color: var(--muted); margin-top: 2px; }
        .perm-list  { display: flex; flex-wrap: wrap; gap: 6px; }
        .perm-chip  { font-size: 11px; padding: 4px 12px; border-radius: 20px; }
        .perm-on    { background: rgba(46,160,67,.12); color: #2ea043; border: 1px solid rgba(46,160,67,.2); }
        .perm-off   { background: rgba(255,255,255,.04); color: var(--faint); border: 1px solid var(--border); }

        /* ── Exercícios grid ── */
        .exer-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
        .exer-card { background: var(--bg3); border: 1px solid var(--border); border-radius: 10px; padding: 14px; }
        .exer-tag  { font-size: 10px; color: var(--gold); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 5px; }
        .exer-name { font-size: 13px; color: #fff; font-weight: 500; margin-bottom: 4px; }
        .exer-meta { font-size: 11px; color: var(--muted); }
        .dot-green { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #2ea043; margin-right: 4px; vertical-align: middle; }

        /* ── Activity ── */
        .activity-item { display: flex; align-items: flex-start; gap: 10px; padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,.04); }
        .activity-item:last-child { border-bottom: none; }
        .act-dot { width: 8px; height: 8px; border-radius: 50%; margin-top: 5px; flex-shrink: 0; }
        .act-dot.red  { background: var(--red); }
        .act-dot.gold { background: var(--gold); }
        .act-text { font-size: 12px; color: rgba(255,255,255,.55); line-height: 1.55; }
        .act-text b { color: rgba(255,255,255,.85); font-weight: 500; }
        .act-time { font-size: 10px; color: rgba(255,255,255,.2); margin-top: 2px; }

        /* ── Form ── */
        .form-group { margin-bottom: 18px; }
        .form-label { display: block; font-size: 11px; color: rgba(255,255,255,.45); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 7px; }
        .form-control {
            width: 100%; background: rgba(255,255,255,.04); border: 1px solid var(--border);
            border-radius: 10px; padding: 12px 16px; color: rgba(255,255,255,.85); font-size: 14px;
            outline: none; transition: border-color .2s;
        }
        .form-control:focus { border-color: var(--red); box-shadow: 0 0 0 2px rgba(238,25,32,.15); }
        .form-control::placeholder { color: rgba(255,255,255,.18); }
        .field-validation-error { font-size: 11px; color: var(--red); margin-top: 4px; display: block; }

        /* ── Responsivo ── */
        @@media (max-width: 900px) {
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
            .exer-grid  { grid-template-columns: repeat(2, 1fr); }
            .two-col    { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
<div class="admin-wrap">

    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <img src="~/img/Logo_sem_fundo.png" alt="BulkingPro" />
            <div class="sidebar-brand-role">Administrador</div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section">Principal</div>
            <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")"
               asp-controller="Admin" asp-action="Index">
                <i class="ti ti-layout-dashboard"></i> Dashboard
            </a>

            <div class="nav-section">Pessoas</div>
            <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Personais" ? "active" : "")"
               asp-controller="Admin" asp-action="Personais">
                <i class="ti ti-users"></i> Personais
            </a>
            <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Alunos" ? "active" : "")"
               asp-controller="Admin" asp-action="Alunos">
                <i class="ti ti-user"></i> Alunos
            </a>

            <div class="nav-section">Academia</div>
            <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Exercicios" ? "active" : "")"
               asp-controller="Admin" asp-action="Exercicios">
                <i class="ti ti-barbell"></i> Exercícios
            </a>
            <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Planos" ? "active" : "")"
               asp-controller="Admin" asp-action="Planos">
                <i class="ti ti-clipboard-list"></i> Planos de treino
            </a>

            <div class="nav-section">Sistema</div>
            <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Permissoes" ? "active" : "")"
               asp-controller="Admin" asp-action="Permissoes">
                <i class="ti ti-shield-lock"></i> Permissões
            </a>
            <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Configuracoes" ? "active" : "")"
               asp-controller="Account" asp-action="Configuracoes">
                <i class="ti ti-settings"></i> Minha conta
            </a>
        </nav>

        <div class="sidebar-footer">
            @{
                var nomeAdmin = User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value
                             ?? User.FindFirst("NomeCompleto")?.Value
                             ?? User.Identity?.Name
                             ?? "Admin";
                var iniciaisAdmin = nomeAdmin.Length >= 2
                    ? nomeAdmin[0].ToString().ToUpper() + nomeAdmin.Split(' ').Last()[0].ToString().ToUpper()
                    : nomeAdmin[0].ToString().ToUpper();
            }
            <div class="avatar">@iniciaisAdmin</div>
            <div style="flex:1;min-width:0">
                <div class="avatar-name" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@nomeAdmin</div>
                <div class="avatar-email">Administrador</div>
            </div>
            <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0">
                @Html.AntiForgeryToken()
                <button type="submit" title="Sair" style="background:none;border:none;cursor:pointer;color:rgba(255,255,255,0.3);padding:4px;border-radius:6px;transition:color .15s" onmouseover="this.style.color='#ee1920'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">
                    <i class="ti ti-logout" style="font-size:18px"></i>
                </button>
            </form>
        </div>
    </aside>

    <!-- Conteúdo principal -->
    <div class="main">
        @RenderSection("Topbar", required: false)
        <div class="content">
            @if (TempData["Sucesso"] != null)
            {
                <div class="alert alert-success">
                    <i class="ti ti-circle-check"></i> @TempData["Sucesso"]
                </div>
            }
            @if (TempData["Erro"] != null)
            {
                <div class="alert alert-danger">
                    <i class="ti ti-alert-circle"></i> @TempData["Erro"]
                </div>
            }
            @RenderBody()
        </div>
    </div>

</div>

@RenderSection("Scripts", required: false)
</body>
</html>