@model List<BulkingPro.Models.PlanoTreino>
@{
    Layout = "~/Views/Personal/_PersonalLayout.cshtml";
    ViewData["Title"]      = "Planos de Treino";
    ViewData["ActivePage"] = "PlanoTreino";

    var alunos = ViewBag.Alunos as System.Collections.IEnumerable;
}

@section Topbar {
    <div class="topbar">
        <div>
            <div class="topbar-title">Planos de Treino</div>
            <div class="topbar-sub">@Model.Count plano(s) criado(s)</div>
        </div>
        <div class="topbar-actions">
            <a class="btn btn-primary" asp-action="CriarPlano">
                <i class="ti ti-plus"></i> Novo plano
            </a>
        </div>
    </div>
}

<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th>Plano</th>
                <th>Aluno</th>
                <th>Objetivo</th>
                <th>Início</th>
                <th>Status</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td class="bold">@p.Titulo</td>
                    <td>@p.Aluno?.NomeCompleto</td>
                    <td>@p.Objetivo</td>
                    <td>@p.DataInicio.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if (p.Status == 1) { <span class="badge badge-active">Ativo</span> }
                        else                { <span class="badge badge-inactive">Encerrado</span> }
                    </td>
                    <td>
                        <a class="btn btn-ghost btn-sm" asp-action="CriarPlano" asp-route-alunoId="@p.AlunoId">
                            <i class="ti ti-copy"></i> Novo
                        </a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="6" style="text-align:center;color:var(--muted);padding:28px">Nenhum plano criado ainda.</td></tr>
            }
        </tbody>
    </table>
</div>
