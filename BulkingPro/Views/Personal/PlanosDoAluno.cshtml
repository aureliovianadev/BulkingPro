@using BulkingPro.ViewModels
@model PlanosDoAlunoViewModel
@{
    Layout = "~/Views/Personal/_PersonalLayout.cshtml";
    ViewData["Title"] = $"Planos - {Model.AlunoNome}";
    ViewData["ActivePage"] = "PlanoTreino";
}

@section Topbar {
    <div class="topbar">
        <div>
            <div class="topbar-title">Planos de @Model.AlunoNome</div>
            <div class="topbar-sub">@Model.Planos.Count @(Model.Planos.Count == 1 ? "plano cadastrado" : "planos cadastrados")</div>
        </div>
        <div class="topbar-actions">
            <a class="btn btn-ghost" asp-action="PlanosTreino">
                <i class="ti ti-arrow-left"></i> Voltar
            </a>
            <a class="btn btn-primary" asp-action="CriarPlano" asp-route-alunoId="@Model.AlunoId">
                <i class="ti ti-plus"></i> Novo plano
            </a>
        </div>
    </div>
}

<div class="planos-lista">
    @foreach (var plano in Model.Planos)
    {
        <div class="plano-card">
            <div class="plano-header">
                <div class="plano-info">
                    <div class="plano-titulo">
                        @plano.Titulo
                        @if (plano.IsAtivo)
                        {
                            <span class="ativo-badge">Atual</span>
                        }
                    </div>
                    <div class="plano-meta">
                        <span class="meta-chip">
                            <i class="ti ti-target"></i> @plano.Objetivo
                        </span>
                        <span class="meta-chip">
                            <i class="ti ti-calendar"></i> Criado em @plano.DataCriacao.ToString("dd/MM/yyyy")
                        </span>
                    </div>
                </div>
                <div class="plano-status">
                    @if (plano.IsAtivo)
                    {
                        <span class="badge badge-active">
                            <i class="ti ti-circle-check"></i> Ativo
                        </span>
                    }
                    else
                    {
                        <span class="badge badge-inactive">
                            <i class="ti ti-circle-x"></i> Encerrado
                        </span>
                    }
                </div>
            </div>

            <div class="plano-actions">
                <a class="btn btn-ghost btn-sm" asp-action="VisualizarPlano" asp-route-id="@plano.Id">
                    <i class="ti ti-eye"></i> Ver
                </a>
                
                <a class="btn btn-ghost btn-sm" asp-action="EditarPlano" asp-route-id="@plano.Id">
                    <i class="ti ti-edit"></i> Editar
                </a>
                
                <form asp-action="DuplicarPlano" method="post" style="display:inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@plano.Id" />
                    <button type="submit" class="btn btn-ghost btn-sm btn-duplicar">
                        <i class="ti ti-copy"></i> Duplicar
                    </button>
                </form>
                
                <form asp-action="ExcluirPlano" method="post" style="display:inline" 
                      onsubmit="return confirm('Tem certeza que deseja excluir o plano \'@plano.Titulo\'? Esta ação não pode ser desfeita.');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@plano.Id" />
                    <button type="submit" class="btn btn-danger btn-sm">
                        <i class="ti ti-trash"></i> Excluir
                    </button>
                </form>
            </div>
        </div>
    }
</div>

@if (!Model.Planos.Any())
{
    <div class="empty-state">
        <i class="ti ti-clipboard-list"></i>
        <p>Nenhum plano cadastrado para @Model.AlunoNome.</p>
        <a class="btn btn-primary" asp-action="CriarPlano" asp-route-alunoId="@Model.AlunoId">
            <i class="ti ti-plus"></i> Criar primeiro plano
        </a>
    </div>
}

<style>
    .planos-lista {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .plano-card {
        background: var(--bg3);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 18px 20px;
        transition: all 0.2s ease;
    }

    .plano-card:hover {
        border-color: rgba(238, 25, 32, 0.3);
        background: rgba(255, 255, 255, 0.02);
    }

    .plano-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 14px;
        padding-bottom: 12px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .plano-titulo {
        font-size: 15px;
        font-weight: 600;
        color: #fff;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .ativo-badge {
        font-size: 9px;
        font-weight: 600;
        background: linear-gradient(135deg, #2ea043, #1a6e2e);
        color: #fff;
        padding: 2px 8px;
        border-radius: 20px;
        letter-spacing: 0.5px;
    }

    .plano-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .meta-chip {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        color: var(--muted);
        background: rgba(255, 255, 255, 0.04);
        padding: 4px 10px;
        border-radius: 20px;
    }

    .meta-chip i {
        font-size: 11px;
        color: var(--gold);
    }

    .plano-status {
        flex-shrink: 0;
    }

    .badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 10px;
        font-weight: 500;
        padding: 3px 10px;
        border-radius: 20px;
    }

    .badge-active {
        background: rgba(46, 160, 67, 0.12);
        color: #2ea043;
        border: 1px solid rgba(46, 160, 67, 0.2);
    }

    .badge-inactive {
        background: rgba(255, 255, 255, 0.06);
        color: var(--muted);
        border: 1px solid var(--border);
    }

    .plano-actions {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
        flex-wrap: wrap;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border-radius: 20px;
        padding: 8px 18px;
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        border: none;
        text-decoration: none;
        transition: opacity .15s;
    }

    .btn:hover {
        opacity: .85;
    }

    .btn-sm {
        padding: 5px 12px;
        font-size: 11px;
    }

    .btn-primary {
        background: var(--red);
        color: #fff;
    }

    .btn-ghost {
        background: rgba(255, 255, 255, .05);
        color: var(--muted);
        border: 1px solid var(--border);
    }

    .btn-danger {
        background: rgba(238, 25, 32, 0.15);
        color: #ee1920;
        border: 1px solid rgba(238, 25, 32, 0.25);
    }

    .btn-danger:hover {
        background: rgba(238, 25, 32, 0.25);
    }

    .btn-duplicar {
        color: var(--gold);
        border-color: rgba(196, 168, 122, 0.3);
    }

    .btn-duplicar:hover {
        background: rgba(196, 168, 122, 0.1);
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: rgba(255, 255, 255, 0.3);
    }

    .empty-state i {
        font-size: 48px;
        display: block;
        margin-bottom: 12px;
        color: rgba(238, 25, 32, 0.3);
    }

    .empty-state p {
        margin-bottom: 20px;
        font-size: 14px;
    }

    @@media (max-width: 600px) {
        .plano-header {
            flex-direction: column;
        }
        
        .plano-actions {
            justify-content: flex-start;
        }
    }
</style>