@model BulkingPro.ViewModels.ConfiguracoesViewModel
@{
    // Detecta o layout baseado na role
    if (User.IsInRole("Administrador"))
    {
        Layout = "~/Views/Admin/_AdminLayout.cshtml";
        ViewData["ActivePage"] = "Configuracoes";
    }
    else if (User.IsInRole("Moderador"))
    {
        Layout = "~/Views/Personal/_PersonalLayout.cshtml";
        ViewData["ActivePage"] = "Configuracoes";
    }
    else
    {
        Layout = null;
    }
    ViewData["Title"] = "Minha conta";
}

@section Topbar {
    <div class="topbar">
        <div>
            <div class="topbar-title">Minha conta</div>
            <div class="topbar-sub">Editar informações de acesso</div>
        </div>
    </div>
}

<div style="max-width:520px;display:flex;flex-direction:column;gap:16px">

    <!-- Nome -->
    <div class="card">
        <div class="card-body">
            <div class="card-title"><i class="ti ti-user"></i> Dados pessoais</div>
            <form asp-controller="Account" asp-action="AtualizarNome" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label">Nome completo</label>
                    <input class="form-control" asp-for="NomeCompleto" placeholder="Seu nome" />
                    <span asp-validation-for="NomeCompleto" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">E-mail</label>
                    <input class="form-control" asp-for="Email" type="email" placeholder="seu@email.com" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="ti ti-device-floppy"></i> Salvar dados
                </button>
            </form>
        </div>
    </div>

    <!-- Senha -->
    <div class="card">
        <div class="card-body">
            <div class="card-title"><i class="ti ti-lock"></i> Alterar senha</div>
            <form asp-controller="Account" asp-action="AlterarSenha" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label">Senha atual</label>
                    <input class="form-control" asp-for="SenhaAtual" type="password" placeholder="••••••••" />
                    <span asp-validation-for="SenhaAtual" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">Nova senha</label>
                    <input class="form-control" asp-for="NovaSenha" type="password" placeholder="Mínimo 6 caracteres" />
                    <span asp-validation-for="NovaSenha" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">Confirmar nova senha</label>
                    <input class="form-control" asp-for="ConfirmarSenha" type="password" placeholder="Repita a nova senha" />
                    <span asp-validation-for="ConfirmarSenha" class="field-validation-error"></span>
                </div>
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="ti ti-lock-check"></i> Alterar senha
                </button>
            </form>
        </div>
    </div>

    <!-- Sair -->
    <div class="card" style="border-color:rgba(238,25,32,0.2)">
        <div class="card-body">
            <div class="card-title" style="color:rgba(238,25,32,0.7)"><i class="ti ti-logout"></i> Sair da conta</div>
            <p style="font-size:13px;color:var(--muted);margin-bottom:16px">
                Encerra sua sessão atual. Você precisará fazer login novamente para acessar o sistema.
            </p>
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">
                    <i class="ti ti-logout"></i> Sair agora
                </button>
            </form>
        </div>
    </div>

</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
