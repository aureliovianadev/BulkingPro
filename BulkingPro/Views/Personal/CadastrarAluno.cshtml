@model BulkingPro.ViewModels.CriarPersonalViewModel
@{
    Layout = "~/Views/Personal/_PersonalLayout.cshtml";
    ViewData["Title"] = "Cadastrar Aluno";
    ViewData["ActivePage"] = "CadastrarAluno";
}

@section Topbar {
    <div class="topbar">
        <div>
            <div class="topbar-title">Cadastrar Aluno</div>
            <div class="topbar-sub">Preencha os dados e os horários de atendimento</div>
        </div>
        <div class="topbar-actions">
            <a class="btn btn-ghost" asp-action="Alunos"><i class="ti ti-arrow-left"></i> Voltar</a>
        </div>
    </div>
}

<div class="card">
    <div class="card-body">
        <form asp-action="CadastrarAluno" method="post" id="form-cadastro">
            @Html.AntiForgeryToken()

            <!-- Dados Pessoais -->
            <div class="card-title"><i class="ti ti-user"></i> Dados Pessoais</div>
            
            <div class="form-group">
                <label class="form-label" asp-for="NomeCompleto">Nome completo</label>
                <input class="form-control" asp-for="NomeCompleto" placeholder="Nome do aluno" />
                <span asp-validation-for="NomeCompleto" class="field-validation-error"></span>
            </div>
            
            <div class="form-group">
                <label class="form-label" asp-for="Cpf">CPF</label>
                <input class="form-control" asp-for="Cpf" id="cpf" placeholder="000.000.000-00" />
            </div>
            
            <div class="form-group">
                <label class="form-label" asp-for="Email">E-mail</label>
                <input class="form-control" asp-for="Email" type="email" placeholder="aluno@email.com" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>
            
            <div class="form-group">
                <label class="form-label" asp-for="Telefone">WhatsApp</label>
                <input class="form-control" asp-for="Telefone" id="telefone" placeholder="(00) 00000-0000" />
            </div>
            
            <div class="form-group">
                <label class="form-label" asp-for="Senha">Senha inicial</label>
                <input class="form-control" asp-for="Senha" type="password" placeholder="Mínimo 6 caracteres" />
                <span asp-validation-for="Senha" class="field-validation-error"></span>
            </div>

            <!-- Horários de Atendimento -->
            <div class="card-title" style="margin-top:24px"><i class="ti ti-clock"></i> Horários de Atendimento</div>
            <p class="subtitulo">Adicione os horários que este aluno irá treinar e selecione os dias</p>

            <div id="horarios-container"></div>

            <button type="button" class="btn-add-horario" onclick="adicionarHorario()">
                <i class="ti ti-plus"></i> Adicionar horário
            </button>

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(""))
            {
                <div class="alert alert-danger" style="margin-top:16px">
                    @foreach (var e in ViewData.ModelState[""]!.Errors) { <div>@e.ErrorMessage</div> }
                </div>
            }

            <button type="submit" class="btn-cadastrar">
                <i class="ti ti-user-plus"></i> Cadastrar Aluno
            </button>
        </form>
    </div>
</div>

<script>
    let horarioIndex = 0;

    function adicionarHorario() {
        const container = document.getElementById('horarios-container');
        const card = document.createElement('div');
        card.className = 'horario-card';
        card.setAttribute('data-index', horarioIndex);
        card.innerHTML = `
            <div class="horario-header">
                <div class="horario-titulo">
                    <span><i class="ti ti-clock"></i> Horário ${horarioIndex + 1}</span>
                    <button type="button" class="btn-remove" onclick="removerHorario(this)">×</button>
                </div>
                <div class="horario-inputs">
                    <div class="time-field">
                        <label>De</label>
                        <input type="time" name="HorariosAtendimento[${horarioIndex}].HoraInicio" class="time-input" required />
                    </div>
                    <div class="time-field">
                        <label>Até</label>
                        <input type="time" name="HorariosAtendimento[${horarioIndex}].HoraFim" class="time-input" required />
                    </div>
                </div>
            </div>
            <div class="horario-dias">
                <label class="dias-label">Dias da semana:</label>
                <div class="dias-buttons">
                    <label class="dia-btn"><input type="checkbox" name="HorariosAtendimento[${horarioIndex}].Segunda" /> <span>SEG</span></label>
                    <label class="dia-btn"><input type="checkbox" name="HorariosAtendimento[${horarioIndex}].Terca" /> <span>TER</span></label>
                    <label class="dia-btn"><input type="checkbox" name="HorariosAtendimento[${horarioIndex}].Quarta" /> <span>QUA</span></label>
                    <label class="dia-btn"><input type="checkbox" name="HorariosAtendimento[${horarioIndex}].Quinta" /> <span>QUI</span></label>
                    <label class="dia-btn"><input type="checkbox" name="HorariosAtendimento[${horarioIndex}].Sexta" /> <span>SEX</span></label>
                    <label class="dia-btn"><input type="checkbox" name="HorariosAtendimento[${horarioIndex}].Sabado" /> <span>SAB</span></label>
                    <label class="dia-btn"><input type="checkbox" name="HorariosAtendimento[${horarioIndex}].Domingo" /> <span>DOM</span></label>
                </div>
            </div>
        `;
        container.appendChild(card);
        horarioIndex++;
    }

    function removerHorario(btn) {
        btn.closest('.horario-card').remove();
    }

    // Adicionar primeiro horário automaticamente
    if (document.getElementById('horarios-container').children.length === 0) {
        adicionarHorario();
    }

    // Máscaras
    document.getElementById('cpf')?.addEventListener('input', function(e) {
        let value = e.target.value.replace(/\D/g, '');
        if (value.length <= 11) {
            value = value.replace(/(\d{3})(\d)/, '$1.$2');
            value = value.replace(/(\d{3})(\d)/, '$1.$2');
            value = value.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
            e.target.value = value;
        }
    });

    document.getElementById('telefone')?.addEventListener('input', function(e) {
        let value = e.target.value.replace(/\D/g, '');
        if (value.length <= 11) {
            value = value.replace(/(\d{2})(\d)/, '($1) $2');
            value = value.replace(/(\d{5})(\d)/, '$1-$2');
            e.target.value = value;
        }
    });
</script>

<style>
    .form-group {
        margin-bottom: 16px;
    }

    .subtitulo {
        font-size: 12px;
        color: var(--muted);
        margin-bottom: 20px;
    }

    /* Card de horário */
    .horario-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 16px;
    }
    .horario-header {
        margin-bottom: 14px;
        padding-bottom: 8px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .horario-titulo {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
        font-weight: 600;
        color: var(--gold);
    }
    .horario-titulo i {
        margin-right: 8px;
    }
    .btn-remove {
        background: rgba(238,25,32,0.15);
        border: none;
        color: #ee1920;
        width: 26px;
        height: 26px;
        border-radius: 50%;
        font-size: 16px;
        cursor: pointer;
        transition: all 0.2s;
    }
    .btn-remove:hover {
        background: rgba(238,25,32,0.3);
    }

    /* Inputs de horário */
    .horario-inputs {
        display: flex;
        gap: 16px;
        margin-bottom: 16px;
    }
    .time-field {
        flex: 1;
    }
    .time-field label {
        display: block;
        font-size: 10px;
        color: rgba(255,255,255,0.4);
        text-transform: uppercase;
        margin-bottom: 6px;
    }
    .time-input {
        width: 100%;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px;
        padding: 10px 12px;
        color: #fff;
        font-size: 14px;
        font-family: monospace;
    }
    .time-input:focus {
        border-color: var(--red);
        outline: none;
    }

    /* Dias da semana */
    .dias-label {
        display: block;
        font-size: 10px;
        color: rgba(255,255,255,0.4);
        text-transform: uppercase;
        margin-bottom: 10px;
    }
    .dias-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }
    .dia-btn {
        cursor: pointer;
    }
    .dia-btn input {
        display: none;
    }
    .dia-btn span {
        display: inline-block;
        padding: 6px 14px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 20px;
        font-size: 11px;
        font-weight: 500;
        color: rgba(255,255,255,0.6);
        transition: all 0.2s;
    }
    .dia-btn input:checked + span {
        background: var(--red);
        border-color: var(--red);
        color: #fff;
    }
    .dia-btn:hover span {
        border-color: var(--red);
    }

    /* Botão adicionar */
    .btn-add-horario {
        width: 100%;
        background: rgba(255,255,255,0.03);
        border: 1px dashed rgba(255,255,255,0.2);
        border-radius: 10px;
        padding: 10px;
        font-size: 12px;
        color: var(--gold);
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        margin-top: 4px;
    }
    .btn-add-horario:hover {
        background: rgba(255,255,255,0.06);
        border-color: var(--gold);
    }

    /* Botão cadastrar */
    .btn-cadastrar {
        width: 100%;
        background: linear-gradient(135deg, #ee1920 0%, #c41218 100%);
        border: none;
        border-radius: 30px;
        padding: 14px;
        font-size: 14px;
        font-weight: 600;
        color: #fff;
        cursor: pointer;
        margin-top: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }
    .btn-cadastrar:hover {
        transform: translateY(-1px);
        opacity: 0.9;
    }

    @@media (max-width: 600px) {
        .horario-inputs {
            flex-direction: column;
            gap: 10px;
        }
        .dia-btn span {
            padding: 5px 10px;
            font-size: 10px;
        }
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}