@model BulkingPro.ViewModels.EditarAlunoViewModel
@{
    Layout = "~/Views/Personal/_PersonalLayout.cshtml";
    ViewData["Title"] = "Editar Aluno";
    ViewData["ActivePage"] = "Alunos";
}

@section Topbar {
    <div class="topbar">
        <div>
            <div class="topbar-title">Editar Aluno</div>
            <div class="topbar-sub">Altere os dados e horários de atendimento</div>
        </div>
        <div class="topbar-actions">
            <a class="btn btn-ghost" asp-action="Alunos"><i class="ti ti-arrow-left"></i> Voltar</a>
        </div>
    </div>
}

<div class="card">
    <div class="card-body">
        <form asp-action="EditarAluno" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <!-- Dados Pessoais -->
            <div class="card-title"><i class="ti ti-user"></i> Dados Pessoais</div>
            <div class="form-row">
                <div class="form-group" style="flex:2">
                    <label class="form-label" asp-for="NomeCompleto">Nome completo</label>
                    <input class="form-control" asp-for="NomeCompleto" />
                    <span asp-validation-for="NomeCompleto" class="field-validation-error"></span>
                </div>
                <div class="form-group" style="flex:1">
                    <label class="form-label" asp-for="Cpf">CPF</label>
                    <input class="form-control" asp-for="Cpf" id="cpf" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group" style="flex:2">
                    <label class="form-label" asp-for="Email">E-mail</label>
                    <input class="form-control" asp-for="Email" type="email" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>
                <div class="form-group" style="flex:1">
                    <label class="form-label" asp-for="Telefone">Telefone (WhatsApp)</label>
                    <input class="form-control" asp-for="Telefone" id="telefone" />
                </div>
            </div>
            <div class="form-group">
                <label class="toggle-label">
                    <input type="checkbox" asp-for="Ativo" class="toggle-input" />
                    <span class="toggle-track"></span>
                    <span class="toggle-text">Aluno ativo</span>
                </label>
            </div>

            <!-- Horários de Atendimento -->
            <div class="card-title" style="margin-top:24px"><i class="ti ti-calendar-clock"></i> Horários de Atendimento</div>
            <p style="font-size:12px;color:var(--muted);margin-bottom:16px">Defina os dias e horários que este aluno irá treinar</p>

            <div id="horarios-container">
                @for (int i = 0; i < Model.HorariosAtendimento.Count; i++)
                {
                    var h = Model.HorariosAtendimento[i];
                    <div class="horario-row" style="display:flex;gap:10px;margin-bottom:10px;align-items:center">
                        <input type="hidden" name="HorariosAtendimento[@i].Id" value="@h.Id" />
                        <select name="HorariosAtendimento[@i].DiaSemana" class="form-control" style="flex:1">
                            <option value="">Selecione o dia</option>
                            <option value="0" selected="@(h.DiaSemana == DayOfWeek.Sunday)">Domingo</option>
                            <option value="1" selected="@(h.DiaSemana == DayOfWeek.Monday)">Segunda-feira</option>
                            <option value="2" selected="@(h.DiaSemana == DayOfWeek.Tuesday)">Terça-feira</option>
                            <option value="3" selected="@(h.DiaSemana == DayOfWeek.Wednesday)">Quarta-feira</option>
                            <option value="4" selected="@(h.DiaSemana == DayOfWeek.Thursday)">Quinta-feira</option>
                            <option value="5" selected="@(h.DiaSemana == DayOfWeek.Friday)">Sexta-feira</option>
                            <option value="6" selected="@(h.DiaSemana == DayOfWeek.Saturday)">Sábado</option>
                        </select>
                        <input type="time" name="HorariosAtendimento[@i].HoraInicio" class="form-control" style="flex:1" value="@(h.HoraInicio.HasValue ? h.HoraInicio.Value.ToString(@"hh\:mm") : "")" />
                        <input type="time" name="HorariosAtendimento[@i].HoraFim" class="form-control" style="flex:1" value="@(h.HoraFim.HasValue ? h.HoraFim.Value.ToString(@"hh\:mm") : "")" />
                        <button type="button" class="btn btn-danger btn-sm" onclick="removerHorario(this, @i)">
                            <i class="ti ti-trash"></i>
                        </button>
                    </div>
                }
            </div>
            <button type="button" class="btn btn-ghost btn-sm" onclick="adicionarHorario()" style="margin-top:8px">
                <i class="ti ti-plus"></i> Adicionar outro horário
            </button>

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(""))
            {
                <div class="alert alert-danger" style="margin-top:16px">
                    @foreach (var e in ViewData.ModelState[""]!.Errors) { <div>@e.ErrorMessage</div> }
                </div>
            }

            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:24px">
                <i class="ti ti-device-floppy"></i> Salvar alterações
            </button>
        </form>
    </div>
</div>

<script>
    let horarioIndex = @Model.HorariosAtendimento.Count;

    function adicionarHorario() {
        const container = document.getElementById('horarios-container');
        const newRow = document.createElement('div');
        newRow.className = 'horario-row';
        newRow.style.display = 'flex';
        newRow.style.gap = '10px';
        newRow.style.marginBottom = '10px';
        newRow.style.alignItems = 'center';
        newRow.innerHTML = `
            <input type="hidden" name="HorariosAtendimento[${horarioIndex}].Id" value="0" />
            <select name="HorariosAtendimento[${horarioIndex}].DiaSemana" class="form-control" style="flex:1">
                <option value="">Selecione o dia</option>
                <option value="0">Domingo</option>
                <option value="1">Segunda-feira</option>
                <option value="2">Terça-feira</option>
                <option value="3">Quarta-feira</option>
                <option value="4">Quinta-feira</option>
                <option value="5">Sexta-feira</option>
                <option value="6">Sábado</option>
            </select>
            <input type="time" name="HorariosAtendimento[${horarioIndex}].HoraInicio" class="form-control" style="flex:1" />
            <input type="time" name="HorariosAtendimento[${horarioIndex}].HoraFim" class="form-control" style="flex:1" />
            <button type="button" class="btn btn-danger btn-sm" onclick="removerHorario(this, ${horarioIndex})">
                <i class="ti ti-trash"></i>
            </button>
        `;
        container.appendChild(newRow);
        horarioIndex++;
    }

    function removerHorario(btn, index) {
        // Marca o horário para remoção
        const hiddenField = btn.closest('.horario-row').querySelector('input[name$=".Id"]');
        if (hiddenField && hiddenField.value !== '0') {
            // Adiciona o ID à lista de remoção
            const inputRemover = document.createElement('input');
            inputRemover.type = 'hidden';
            inputRemover.name = 'HorariosParaRemover';
            inputRemover.value = hiddenField.value;
            document.querySelector('form').appendChild(inputRemover);
        }
        btn.closest('.horario-row').remove();
    }

    // Máscara para CPF e Telefone
    document.getElementById('cpf')?.addEventListener('input', function(e) {
        let value = e.target.value.replace(/\D/g, '');
        if (value.length <= 11) {
            value = value.replace(/(\d{3})(\d)/, '$1.$2');
            value = value.replace(/(\d{3})(\d)/, '$1.$2');
            value = value.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
            e.target.value = value;
        }
    });

    document.getElementById('telefone')?.addEventListener('input', function(e) {
        let value = e.target.value.replace(/\D/g, '');
        if (value.length <= 11) {
            value = value.replace(/(\d{2})(\d)/, '($1) $2');
            value = value.replace(/(\d{5})(\d)/, '$1-$2');
            e.target.value = value;
        }
    });
</script>

<style>
    .toggle-label {
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
    }
    .toggle-input {
        display: none;
    }
    .toggle-track {
        width: 40px;
        height: 22px;
        border-radius: 11px;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.15);
        position: relative;
    }
    .toggle-track::after {
        content: '';
        position: absolute;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: rgba(255,255,255,0.4);
        top: 2px;
        left: 2px;
        transition: all .2s;
    }
    .toggle-input:checked + .toggle-track {
        background: rgba(46,160,67,0.5);
        border-color: #2ea043;
    }
    .toggle-input:checked + .toggle-track::after {
        left: 20px;
        background: #2ea043;
    }
    .toggle-text {
        font-size: 13px;
        color: rgba(255,255,255,0.6);
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}