@model BulkingPro.ViewModels.CriarPersonalViewModel
@{
    Layout = "~/Views/Personal/_PersonalLayout.cshtml";
    ViewData["Title"] = "Cadastrar Aluno";
    ViewData["ActivePage"] = "CadastrarAluno";
}

@section Topbar {
    <div class="topbar">
        <div>
            <div class="topbar-title">Cadastrar Aluno</div>
            <div class="topbar-sub">Preencha os dados e os horários de atendimento</div>
        </div>
        <div class="topbar-actions">
            <a class="btn btn-ghost" asp-action="Alunos"><i class="ti ti-arrow-left"></i> Voltar</a>
        </div>
    </div>
}

<div class="card">
    <div class="card-body">
        <div id="erro-conflito" class="alert alert-danger" style="display:none; margin-bottom:16px">
            <i class="ti ti-alert-circle"></i> <span id="erro-mensagem"></span>
        </div>

        <form asp-action="CadastrarAluno" method="post" id="form-cadastro">
            @Html.AntiForgeryToken()

            <div class="card-title"><i class="ti ti-user"></i> Dados Pessoais</div>

            <div class="form-row">
                <div class="form-group" style="flex:2">
                    <label class="form-label" asp-for="NomeCompleto">Nome completo</label>
                    <input class="form-control" asp-for="NomeCompleto" placeholder="Nome completo do aluno" />
                    <span asp-validation-for="NomeCompleto" class="field-validation-error"></span>
                </div>
                <div class="form-group" style="flex:1">
                    <label class="form-label" asp-for="Cpf">CPF</label>
                    <input class="form-control" asp-for="Cpf" id="cpf" placeholder="000.000.000-00" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group" style="flex:2">
                    <label class="form-label" asp-for="Email">E-mail</label>
                    <input class="form-control" asp-for="Email" type="email" placeholder="aluno@email.com" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>
                <div class="form-group" style="flex:1">
                    <label class="form-label" asp-for="Telefone">WhatsApp</label>
                    <input class="form-control" asp-for="Telefone" id="telefone" placeholder="(00) 00000-0000" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group" style="flex:1">
                    <label class="form-label" asp-for="Senha">Senha</label>
                    <div class="senha-wrapper">
                        <input class="form-control" asp-for="Senha" type="password" id="senha" placeholder="Mínimo 6 caracteres" />
                        <button type="button" class="btn-eye" onclick="toggleSenha('senha', 'eye-senha')">
                            <i class="ti ti-eye" id="eye-senha"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Senha" class="field-validation-error"></span>
                </div>
                <div class="form-group" style="flex:1">
                    <label class="form-label" for="confirmarSenha">Confirmar senha</label>
                    <div class="senha-wrapper">
                        <input class="form-control" type="password" id="confirmarSenha" placeholder="Digite novamente" />
                        <button type="button" class="btn-eye" onclick="toggleSenha('confirmarSenha', 'eye-confirmar')">
                            <i class="ti ti-eye" id="eye-confirmar"></i>
                        </button>
                    </div>
                    <span id="senha-error" class="field-validation-error" style="display:none">As senhas não coincidem</span>
                </div>
            </div>

            <div class="card-title" style="margin-top:24px"><i class="ti ti-clock"></i> Horários de Atendimento</div>
            <p class="subtitulo">Adicione os horários que este aluno irá treinar e selecione os dias</p>

            <div id="horarios-container"></div>

            <button type="button" class="btn-add-horario" onclick="adicionarHorario()">
                <i class="ti ti-plus"></i> Adicionar horário
            </button>

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(""))
            {
                <div class="alert alert-danger" style="margin-top:16px">
                    @foreach (var e in ViewData.ModelState[""]!.Errors)
                    {
                        <div>@e.ErrorMessage</div>
                    }
                </div>
            }

            <button type="submit" class="btn-cadastrar" id="btn-submit">
                <i class="ti ti-user-plus"></i> Cadastrar Aluno
            </button>
        </form>
    </div>
</div>

<script>
    // Função para coletar horários e enviar para validação
    async function verificarConflitoHorarios() {
        const horarios = coletarHorarios();
        
        if (horarios.length === 0) return true;
        
        try {
            const response = await fetch('/Personal/VerificarConflitoHorario', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify(horarios)
            });
            
            const result = await response.json();
            return !result.temConflito;
        } catch (error) {
            console.error('Erro ao verificar conflito:', error);
            return true;
        }
    }
    
    function coletarHorarios() {
        const horarios = [];
        document.querySelectorAll('.horario-card').forEach(card => {
            const horaInicio = card.querySelector('input[name*="HoraInicio"]')?.value;
            const horaFim = card.querySelector('input[name*="HoraFim"]')?.value;
            
            if (!horaInicio || !horaFim) return;
            
            const dias = {
                Domingo: card.querySelector('input[name*="Domingo"]')?.checked || false,
                Segunda: card.querySelector('input[name*="Segunda"]')?.checked || false,
                Terca: card.querySelector('input[name*="Terca"]')?.checked || false,
                Quarta: card.querySelector('input[name*="Quarta"]')?.checked || false,
                Quinta: card.querySelector('input[name*="Quinta"]')?.checked || false,
                Sexta: card.querySelector('input[name*="Sexta"]')?.checked || false,
                Sabado: card.querySelector('input[name*="Sabado"]')?.checked || false
            };
            
            horarios.push({
                horaInicio: horaInicio,
                horaFim: horaFim,
                ...dias
            });
        });
        return horarios;
    }

    function mostrarErro(mensagem) {
        const erroDiv = document.getElementById('erro-conflito');
        const erroMsg = document.getElementById('erro-mensagem');
        erroMsg.innerText = mensagem;
        erroDiv.style.display = 'block';
        setTimeout(() => {
            erroDiv.style.display = 'none';
        }, 5000);
    }

    // Validação de senha e conflito antes de enviar
    document.getElementById('btn-submit').addEventListener('click', async function(e) {
        e.preventDefault();
        
        // Esconde erro anterior
        document.getElementById('erro-conflito').style.display = 'none';
        
        // 1. Verifica se as senhas coincidem
        const senha = document.getElementById('senha').value;
        const confirmar = document.getElementById('confirmarSenha').value;
        const errorSpan = document.getElementById('senha-error');
        
        if (senha !== confirmar) {
            errorSpan.style.display = 'block';
            document.getElementById('confirmarSenha').style.borderColor = '#ee1920';
            return;
        } else {
            errorSpan.style.display = 'none';
            document.getElementById('confirmarSenha').style.borderColor = '';
        }
        
        // 2. Verifica se há pelo menos um horário com dia selecionado
        const temHorarioValido = validarHorarios();
        if (!temHorarioValido) {
            mostrarErro('⚠️ Selecione pelo menos um dia da semana para cada horário.');
            return;
        }
        
        // 3. Verifica conflito de horários via AJAX
        const semConflito = await verificarConflitoHorarios();
        
        if (!semConflito) {
            mostrarErro('❌ Conflito de horário! Já existe um aluno agendado neste mesmo dia e horário.');
            return;
        }
        
        // 4. Se passou por todas as validações, envia o formulário
        document.getElementById('form-cadastro').submit();
    });
    
    function validarHorarios() {
        let temHorarioValido = false;
        document.querySelectorAll('.horario-card').forEach(card => {
            const temDia = card.querySelector('input[name*="Domingo"]:checked') ||
                          card.querySelector('input[name*="Segunda"]:checked') ||
                          card.querySelector('input[name*="Terca"]:checked') ||
                          card.querySelector('input[name*="Quarta"]:checked') ||
                          card.querySelector('input[name*="Quinta"]:checked') ||
                          card.querySelector('input[name*="Sexta"]:checked') ||
                          card.querySelector('input[name*="Sabado"]:checked');
            if (temDia) temHorarioValido = true;
        });
        return temHorarioValido;
    }

    // Remover erro ao digitar
    document.getElementById('confirmarSenha').addEventListener('input', function() {
        const senha = document.getElementById('senha').value;
        const confirmar = this.value;
        const errorSpan = document.getElementById('senha-error');
        
        if (senha === confirmar) {
            errorSpan.style.display = 'none';
            this.style.borderColor = '';
        } else {
            this.style.borderColor = '#ee1920';
        }
    });

    // Alternar visibilidade da senha
    function toggleSenha(inputId, eyeId) {
        const input = document.getElementById(inputId);
        const eye = document.getElementById(eyeId);
        
        if (input.type === 'password') {
            input.type = 'text';
            eye.classList.remove('ti-eye');
            eye.classList.add('ti-eye-off');
        } else {
            input.type = 'password';
            eye.classList.remove('ti-eye-off');
            eye.classList.add('ti-eye');
        }
    }

    let horarioIndex = 0;

    function reindexarHorarios() {
        const cards = document.querySelectorAll('.horario-card');
        cards.forEach((card, i) => {
            card.setAttribute('data-index', i);
            card.querySelector('.horario-titulo span').innerHTML =
                `<i class="ti ti-clock"></i> Horário ${i + 1}`;
            card.querySelectorAll('input[name]').forEach(input => {
                input.name = input.name.replace(/HorariosAtendimento\[\d+\]/, `HorariosAtendimento[${i}]`);
            });
        });
        horarioIndex = cards.length;
    }

    function adicionarHorario() {
        reindexarHorarios();
        const container = document.getElementById('horarios-container');
        const i = horarioIndex;
        const card = document.createElement('div');
        card.className = 'horario-card';
        card.setAttribute('data-index', i);
        card.innerHTML = `
            <div class="horario-header">
                <div class="horario-titulo">
                    <span><i class="ti ti-clock"></i> Horário ${i + 1}</span>
                    <button type="button" class="btn-remove" onclick="removerHorario(this)">×</button>
                </div>
                <div class="horario-inputs">
                    <div class="time-field">
                        <label>De</label>
                        <input type="time" name="HorariosAtendimento[${i}].HoraInicio" class="time-input" />
                    </div>
                    <div class="time-field">
                        <label>Até</label>
                        <input type="time" name="HorariosAtendimento[${i}].HoraFim" class="time-input" />
                    </div>
                </div>
            </div>
            <div class="horario-dias">
                <label class="dias-label">Dias da semana:</label>
                <div class="dias-buttons">
                    <label class="dia-btn"><input type="checkbox" name="HorariosAtendimento[${i}].Domingo" value="true" /><span>DOM</span></label>
                    <label class="dia-btn"><input type="checkbox" name="HorariosAtendimento[${i}].Segunda" value="true" /><span>SEG</span></label>
                    <label class="dia-btn"><input type="checkbox" name="HorariosAtendimento[${i}].Terca"   value="true" /><span>TER</span></label>
                    <label class="dia-btn"><input type="checkbox" name="HorariosAtendimento[${i}].Quarta"  value="true" /><span>QUA</span></label>
                    <label class="dia-btn"><input type="checkbox" name="HorariosAtendimento[${i}].Quinta"  value="true" /><span>QUI</span></label>
                    <label class="dia-btn"><input type="checkbox" name="HorariosAtendimento[${i}].Sexta"   value="true" /><span>SEX</span></label>
                    <label class="dia-btn"><input type="checkbox" name="HorariosAtendimento[${i}].Sabado"  value="true" /><span>SAB</span></label>
                </div>
            </div>
        `;
        container.appendChild(card);
        horarioIndex++;
    }

    function removerHorario(btn) {
        btn.closest('.horario-card').remove();
        reindexarHorarios();
    }

    if (document.getElementById('horarios-container').children.length === 0) {
        adicionarHorario();
    }

    document.getElementById('cpf')?.addEventListener('input', function (e) {
        let value = e.target.value.replace(/\D/g, '');
        if (value.length <= 11) {
            value = value.replace(/(\d{3})(\d)/, '$1.$2');
            value = value.replace(/(\d{3})(\d)/, '$1.$2');
            value = value.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
            e.target.value = value;
        }
    });

    document.getElementById('telefone')?.addEventListener('input', function (e) {
        let value = e.target.value.replace(/\D/g, '');
        if (value.length <= 11) {
            value = value.replace(/(\d{2})(\d)/, '($1) $2');
            value = value.replace(/(\d{5})(\d)/, '$1-$2');
            e.target.value = value;
        }
    });
</script>

<style>
    .form-row { display: flex; gap: 14px; margin-bottom: 16px; }
    .form-group { margin-bottom: 0; flex: 1; }

    .subtitulo {
        font-size: 12px;
        color: var(--muted);
        margin-bottom: 20px;
    }

    /* Wrapper para senha com olhinho */
    .senha-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }
    .senha-wrapper .form-control {
        flex: 1;
        padding-right: 40px;
    }
    .btn-eye {
        position: absolute;
        right: 10px;
        background: none;
        border: none;
        color: rgba(255,255,255,0.5);
        cursor: pointer;
        padding: 0;
        font-size: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: color 0.2s;
    }
    .btn-eye:hover {
        color: var(--gold);
    }

    .horario-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 16px;
    }

    .horario-header {
        margin-bottom: 14px;
        padding-bottom: 8px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .horario-titulo {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
        font-weight: 600;
        color: var(--gold);
        margin-bottom: 14px;
    }

    .horario-titulo i { margin-right: 8px; }

    .btn-remove {
        background: rgba(238,25,32,0.15);
        border: none;
        color: #ee1920;
        width: 26px;
        height: 26px;
        border-radius: 50%;
        font-size: 16px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-remove:hover { background: rgba(238,25,32,0.3); }

    .horario-inputs {
        display: flex;
        gap: 16px;
        margin-bottom: 16px;
    }

    .time-field { flex: 1; }

    .time-field label {
        display: block;
        font-size: 10px;
        color: rgba(255,255,255,0.4);
        text-transform: uppercase;
        margin-bottom: 6px;
    }

    .time-input {
        width: 100%;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px;
        padding: 10px 12px;
        color: #fff;
        font-size: 14px;
        font-family: monospace;
    }

    .time-input:focus {
        border-color: var(--red);
        outline: none;
    }

    .dias-label {
        display: block;
        font-size: 10px;
        color: rgba(255,255,255,0.4);
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .dias-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .dia-btn { cursor: pointer; }

    .dia-btn input { display: none; }

    .dia-btn span {
        display: inline-block;
        padding: 6px 14px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 20px;
        font-size: 11px;
        font-weight: 500;
        color: rgba(255,255,255,0.6);
        transition: all 0.2s;
    }

    .dia-btn input:checked + span {
        background: var(--red);
        border-color: var(--red);
        color: #fff;
    }

    .dia-btn:hover span { border-color: var(--red); }

    .btn-add-horario {
        width: 100%;
        background: rgba(255,255,255,0.03);
        border: 1px dashed rgba(255,255,255,0.2);
        border-radius: 10px;
        padding: 10px;
        font-size: 12px;
        color: var(--gold);
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        margin-top: 4px;
    }

    .btn-add-horario:hover {
        background: rgba(255,255,255,0.06);
        border-color: var(--gold);
    }

    .btn-cadastrar {
        width: 100%;
        background: linear-gradient(135deg, #ee1920 0%, #c41218 100%);
        border: none;
        border-radius: 30px;
        padding: 14px;
        font-size: 14px;
        font-weight: 600;
        color: #fff;
        cursor: pointer;
        margin-top: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all 0.2s;
    }

    .btn-cadastrar:hover {
        transform: translateY(-1px);
        opacity: 0.9;
    }

    .field-validation-error {
        font-size: 11px;
        color: #ee1920;
        margin-top: 4px;
        display: block;
    }

    .alert-danger {
        background: rgba(238,25,32,0.15);
        border: 1px solid rgba(238,25,32,0.3);
        border-radius: 10px;
        padding: 12px 16px;
        color: #ee1920;
        font-size: 13px;
    }

    @@media (max-width: 700px) {
        .form-row { flex-direction: column; gap: 16px; }
        .horario-inputs { flex-direction: column; gap: 10px; }
        .dia-btn span { padding: 5px 10px; font-size: 10px; }
    }
</style>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}