@model BulkingPro.Models.Exercicio
@{
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    ViewData["Title"]      = "Editar Exercício";
    ViewData["ActivePage"] = "Exercicios";
}

@section Topbar {
    <div class="topbar">
        <div>
            <div class="topbar-title">Editar Exercício</div>
            <div class="topbar-sub">@Model.Nome</div>
        </div>
        <div class="topbar-actions">
            <a class="btn btn-ghost" asp-action="Index">
                <i class="ti ti-arrow-left"></i> Voltar
            </a>
        </div>
    </div>
}

<div style="max-width:580px">
    <div class="card">
        <div class="card-body">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="form-row">
                    <div class="form-group" style="flex:2">
                        <label class="form-label" asp-for="Nome">Nome do exercício</label>
                        <input class="form-control" asp-for="Nome" />
                        <span asp-validation-for="Nome" class="field-validation-error"></span>
                    </div>
                    <div class="form-group" style="flex:1">
                        <label class="form-label" asp-for="GrupoMuscularId">Grupo muscular</label>
                        <select class="form-control" asp-for="GrupoMuscularId"
                                asp-items="ViewBag.GrupoMuscularId">
                        </select>
                        <span asp-validation-for="GrupoMuscularId" class="field-validation-error"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="Descricao">Descrição</label>
                    <textarea class="form-control" asp-for="Descricao" rows="3"></textarea>
                    <span asp-validation-for="Descricao" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="InstrucoesExecucao">Instruções de execução</label>
                    <textarea class="form-control" asp-for="InstrucoesExecucao" rows="4"></textarea>
                    <span asp-validation-for="InstrucoesExecucao" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label class="toggle-label">
                        <input type="checkbox" asp-for="Ativo" class="toggle-input" />
                        <span class="toggle-track"></span>
                        <span class="toggle-text">Exercício ativo</span>
                    </label>
                </div>

                <input type="hidden" asp-for="DataCriacao" />
                <input type="hidden" asp-for="DataAtualizacao" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm:ss")" />

                <div style="display:flex;gap:10px;margin-top:8px">
                    <button type="submit" class="btn btn-primary" style="flex:1;justify-content:center">
                        <i class="ti ti-device-floppy"></i> Salvar alterações
                    </button>
                    <a class="btn btn-ghost" asp-action="Index">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .form-row { display: flex; gap: 14px; }
    textarea.form-control { resize: vertical; min-height: 80px; }

    .toggle-label { display: flex; align-items: center; gap: 10px; cursor: pointer; }
    .toggle-input { display: none; }
    .toggle-track {
        width: 40px; height: 22px; border-radius: 11px;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.15);
        position: relative; transition: background .2s;
        flex-shrink: 0;
    }
    .toggle-track::after {
        content: ''; position: absolute;
        width: 16px; height: 16px; border-radius: 50%;
        background: rgba(255,255,255,0.4);
        top: 2px; left: 2px; transition: all .2s;
    }
    .toggle-input:checked + .toggle-track { background: rgba(46,160,67,0.5); border-color: #2ea043; }
    .toggle-input:checked + .toggle-track::after { left: 20px; background: #2ea043; }
    .toggle-text { font-size: 13px; color: rgba(255,255,255,0.6); }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
