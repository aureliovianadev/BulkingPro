<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - BulkingPro</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="layout">
        <aside class="sidebar">
            <div class="logo-area">
                <img src="~/img/Logo.jpg" alt="BulkingPro" />
            </div>
            <nav>
                <a asp-controller="Home" asp-action="Index">Home</a>
                <a asp-controller="Exercicios" asp-action="Index">Exercícios</a>
            </nav>
        </aside>
        <main class="content">
            @RenderBody()
        </main>
    </div>
</body>
</html>