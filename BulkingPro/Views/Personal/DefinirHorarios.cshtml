@model BulkingPro.ViewModels.DefinirHorarioViewModel
@{
    Layout = "~/Views/Personal/_PersonalLayout.cshtml";
    ViewData["Title"] = "Definir Horários";
    ViewData["ActivePage"] = "Agenda";
}

@section Topbar {
    <div class="topbar">
        <div>
            <div class="topbar-title">Definir Horários de Atendimento</div>
            <div class="topbar-sub">Configure seus dias e horários disponíveis</div>
        </div>
        <div class="topbar-actions">
            <a class="btn btn-ghost" asp-action="Agenda">
                <i class="ti ti-arrow-left"></i> Voltar
            </a>
        </div>
    </div>
}

<div style="max-width:480px">
    <div class="card">
        <div class="card-body">
            <form asp-action="DefinirHorarios" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label class="form-label">Dia da semana</label>
                    <select class="form-control" asp-for="DiaSemana" required>
                        <option value="0">Domingo</option>
                        <option value="1">Segunda-feira</option>
                        <option value="2">Terça-feira</option>
                        <option value="3">Quarta-feira</option>
                        <option value="4">Quinta-feira</option>
                        <option value="5">Sexta-feira</option>
                        <option value="6">Sábado</option>
                    </select>
                    <span asp-validation-for="DiaSemana" class="field-validation-error"></span>
                </div>

                <div class="form-row">
                    <div class="form-group" style="flex:1">
                        <label class="form-label">Horário início</label>
                        <input type="time" class="form-control" asp-for="HoraInicio" required />
                        <span asp-validation-for="HoraInicio" class="field-validation-error"></span>
                    </div>
                    <div class="form-group" style="flex:1">
                        <label class="form-label">Horário fim</label>
                        <input type="time" class="form-control" asp-for="HoraFim" required />
                        <span asp-validation-for="HoraFim" class="field-validation-error"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label class="toggle-label">
                        <input type="checkbox" asp-for="Ativo" class="toggle-input" checked />
                        <span class="toggle-track"></span>
                        <span class="toggle-text">Horário ativo</span>
                    </label>
                </div>

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(""))
                {
                    <div class="alert alert-danger">
                        @foreach (var e in ViewData.ModelState[""]!.Errors)
                        {
                            <div>@e.ErrorMessage</div>
                        }
                    </div>
                }

                <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center">
                    <i class="ti ti-device-floppy"></i> Salvar horário
                </button>
            </form>
        </div>
    </div>
</div>

<style>
    .form-row { display: flex; gap: 14px; }
    .toggle-label { display: flex; align-items: center; gap: 10px; cursor: pointer; }
    .toggle-input { display: none; }
    .toggle-track {
        width: 40px; height: 22px; border-radius: 11px;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.15);
        position: relative;
    }
    .toggle-track::after {
        content: '';
        position: absolute;
        width: 16px; height: 16px; border-radius: 50%;
        background: rgba(255,255,255,0.4);
        top: 2px; left: 2px;
        transition: all .2s;
    }
    .toggle-input:checked + .toggle-track { background: rgba(46,160,67,0.5); border-color: #2ea043; }
    .toggle-input:checked + .toggle-track::after { left: 20px; background: #2ea043; }
    .toggle-text { font-size: 13px; color: rgba(255,255,255,0.6); }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}