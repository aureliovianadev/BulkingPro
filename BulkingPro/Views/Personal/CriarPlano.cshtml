@model BulkingPro.ViewModels.CriarPlanoViewModel
@{
    Layout = "~/Views/Personal/_PersonalLayout.cshtml";
    ViewData["Title"] = "Criar Plano de Treino";
    ViewData["ActivePage"] = "PlanoTreino";

    var exercicios = ViewBag.Exercicios as List<BulkingPro.Models.Exercicio> ?? new();
    var grupos = exercicios.GroupBy(e => e.GrupoMuscular?.Nome ?? "Outros").OrderBy(g => g.Key);
}

@section Topbar {
    <div class="topbar">
        <div>
            <div class="topbar-title">Novo Plano de Treino</div>
            <div class="topbar-sub">Configure os dias e exercícios</div>
        </div>
        <div class="topbar-actions">
            <a class="btn btn-ghost" asp-action="PlanosTreino"><i class="ti ti-arrow-left"></i> Voltar</a>
        </div>
    </div>
}

<form asp-action="CriarPlano" method="post" id="form-plano">
    @Html.AntiForgeryToken()

    <!-- INFO GERAL -->
    <div class="card" style="margin-bottom:16px">
        <div class="card-body">
            <div class="card-title"><i class="ti ti-info-circle"></i> Informações do plano</div>
            <div class="form-row">
                <div class="form-group" style="flex:2">
                    <label class="form-label">Aluno</label>
                    <select class="form-control" asp-for="AlunoId" asp-items="ViewBag.Alunos">
                        <option value="">— selecione o aluno —</option>
                    </select>
                    <span asp-validation-for="AlunoId" class="field-validation-error"></span>
                </div>
                <div class="form-group" style="flex:3">
                    <label class="form-label">Título do plano</label>
                    <input class="form-control" asp-for="Titulo" placeholder="Ex.: Hipertrofia A — Ciclo 1" />
                    <span asp-validation-for="Titulo" class="field-validation-error"></span>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Objetivo</label>
                    <input class="form-control" asp-for="Objetivo" placeholder="Ex.: Ganho de massa muscular" />
                </div>
                <div class="form-group">
                    <label class="form-label">Data início</label>
                    <input class="form-control" asp-for="DataInicio" type="date" />
                </div>
                <div class="form-group">
                    <label class="form-label">Data fim (opcional)</label>
                    <input class="form-control" asp-for="DataFim" type="date" />
                </div>
            </div>
        </div>
    </div>

    <!-- CALENDÁRIO SEMANAL -->
    <div class="card" style="margin-bottom:16px">
        <div class="card-body">
            <div class="card-title"><i class="ti ti-calendar-week"></i> Dias de treino</div>
            <p style="font-size:12px;color:var(--muted);margin-bottom:16px">Selecione os dias ativos e adicione os exercícios de cada dia.</p>

            <div class="semana-grid">
                @for (int i = 0; i < Model.DiasSemana.Count; i++)
                {
                    var dia = Model.DiasSemana[i];
                    <div class="dia-card" id="dia-card-@i">

                        <!-- Cabeçalho do dia -->
                        <div class="dia-header">
                            <label class="toggle-label">
                                <input type="checkbox" name="DiasSemana[@i].Selecionado"
                                       class="toggle-input dia-toggle" data-dia="@i"
                                       @(dia.Selecionado ? "checked" : "") />
                                <span class="toggle-track"></span>
                                <span class="toggle-text dia-nome">@dia.Nome</span>
                            </label>
                            <input type="hidden" name="DiasSemana[@i].Nome" value="@dia.Nome" />
                            <input type="hidden" name="DiasSemana[@i].Ordem" value="@dia.Ordem" />
                        </div>

                        <!-- Obs do dia -->
                        <div class="dia-body" id="dia-body-@i" style="@(dia.Selecionado ? "" : "display:none")">
                            <div class="form-group" style="margin-bottom:12px">
                                <label class="form-label">Observações do dia</label>
                                <input class="form-control" name="DiasSemana[@i].Observacoes"
                                       value="@dia.Observacoes" placeholder="Ex.: Foco em peito e tríceps" />
                            </div>

                            <!-- Exercícios do dia -->
                            <div class="card-title" style="font-size:11px;margin-bottom:10px">
                                <i class="ti ti-barbell"></i> Exercícios
                            </div>

                            <div class="exer-lista" id="exer-lista-@i">
                                @for (int j = 0; j < dia.Exercicios.Count; j++)
                                {
                                    var ex = dia.Exercicios[j];
                                    <div class="exer-linha" id="exer-@i-@j">
                                        <div class="exer-num">@(j+1)</div>
                                        <div class="exer-campos">
                                            <!-- Grupo / Exercício -->
                                            <div class="form-row">
                                                <div class="form-group" style="flex:1">
                                                    <label class="form-label">Grupo muscular</label>
                                                    <select class="form-control grupo-sel" data-dia="@i" data-ex="@j" style="font-size:12px">
                                                        <option value="">— grupo —</option>
                                                        @foreach (var g in grupos)
                                                        {
                                                            <option value="@g.Key">@g.Key</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="form-group" style="flex:2">
                                                    <label class="form-label">Exercício</label>
                                                    <select class="form-control exer-sel" data-dia="@i" data-ex="@j"
                                                            name="DiasSemana[@i].Exercicios[@j].ExercicioId" style="font-size:12px">
                                                        <option value="0">— selecione o grupo —</option>
                                                        @foreach (var e in exercicios)
                                                        {
                                                            if (ex.ExercicioId == e.Id)
                                                            {
                                                                <option value="@e.Id" data-grupo="@e.GrupoMuscular?.Nome" data-tipo="@e.TipoExecucao" selected>@e.Nome</option>
                                                            }
                                                            else
                                                            {
                                                                <option value="@e.Id" data-grupo="@e.GrupoMuscular?.Nome" data-tipo="@e.TipoExecucao">@e.Nome</option>
                                                            }
                                                        }
                                                    </select>
                                                </div>
                                            </div>

                                            <!-- Séries / Repetições / Tempo / Carga / Descanso -->
                                            <div class="form-row">
                                                <div class="form-group" style="flex:1">
                                                    <label class="form-label">Séries</label>
                                                    <input class="form-control" type="number" min="1"
                                                           name="DiasSemana[@i].Exercicios[@j].Series"
                                                           value="@ex.Series" />
                                                    <input type="hidden" name="DiasSemana[@i].Exercicios[@j].Ordem" value="@ex.Ordem" />
                                                </div>
                                                <div class="form-group rep-group" style="flex:1" id="rep-group-@i-@j">
                                                    <label class="form-label">Repetições</label>
                                                    <input class="form-control" type="text"
                                                           name="DiasSemana[@i].Exercicios[@j].Repeticoes"
                                                           value="@ex.Repeticoes" placeholder="12" />
                                                </div>
                                                <div class="form-group tempo-group" style="flex:1" id="tempo-group-@i-@j">
                                                    <label class="form-label">Tempo (min)</label>
                                                    <input class="form-control" type="number" step="1" min="0"
                                                           name="DiasSemana[@i].Exercicios[@j].TempoExecucao"
                                                           value="@(ex.TempoExecucao.HasValue ? ex.TempoExecucao.Value / 60 : null)" placeholder="ex: 10" />
                                                </div>
                                                <div class="form-group" style="flex:1">
                                                    <label class="form-label">Carga (kg)</label>
                                                    <input class="form-control" type="number" step="0.5"
                                                           name="DiasSemana[@i].Exercicios[@j].Carga"
                                                           value="@ex.Carga" placeholder="—" />
                                                </div>
                                                <div class="form-group" style="flex:1">
                                                    <label class="form-label">Descanso (s)</label>
                                                    <input class="form-control" type="number"
                                                           name="DiasSemana[@i].Exercicios[@j].Descanso"
                                                           value="@ex.Descanso" placeholder="60" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div style="display:flex;gap:10px">
        <button type="submit" class="btn btn-primary">
            <i class="ti ti-device-floppy"></i> Salvar plano de treino
        </button>
        <a class="btn btn-ghost" asp-action="PlanosTreino">Cancelar</a>
    </div>
</form>

<style>
    .semana-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(380px, 1fr)); gap: 12px; }

    .dia-card {
        background: rgba(255, 255, 255, 0.025);
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 12px;
        overflow: hidden;
    }
    .dia-header {
        padding: 14px 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        background: rgba(255, 255, 255, 0.02);
    }
    .dia-body { padding: 14px 16px; }

    .exer-linha {
        display: flex;
        gap: 10px;
        align-items: flex-start;
        padding: 10px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    }
    .exer-linha:last-child { border-bottom: none; }
    .exer-num {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: rgba(196, 168, 122, 0.15);
        color: var(--gold);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        flex-shrink: 0;
        margin-top: 22px;
    }
    .exer-campos { flex: 1; }
    .form-row { display: flex; gap: 10px; margin-bottom: 8px; }
    .form-row .form-group { margin-bottom: 0; }
</style>

<script>
    // Mostrar/ocultar corpo do dia
    document.querySelectorAll('.dia-toggle').forEach(cb => {
        cb.addEventListener('change', function () {
            const body = document.getElementById('dia-body-' + this.dataset.dia);
            body.style.display = this.checked ? '' : 'none';
        });
    });

    // Filtrar exercícios por grupo
    document.querySelectorAll('.grupo-sel').forEach(sel => {
        sel.addEventListener('change', function () {
            const grupo = this.value;
            const exSel = document.querySelector(
                `.exer-sel[data-dia="${this.dataset.dia}"][data-ex="${this.dataset.ex}"]`);
            if (!exSel) return;
            exSel.querySelectorAll('option').forEach(opt => {
                if (!opt.value || opt.value === '0') { opt.style.display = ''; return; }
                opt.style.display = (!grupo || opt.dataset.grupo === grupo) ? '' : 'none';
            });
            exSel.value = '0';
        });
    });

    // Mostrar/esconder campo de repetições ou tempo baseado no tipo do exercício
    document.querySelectorAll('.exer-sel').forEach(sel => {
        sel.addEventListener('change', function () {
            const selected = this.options[this.selectedIndex];
            const tipo = selected?.dataset?.tipo;
            const dia = this.dataset.dia;
            const ex = this.dataset.ex;

            const repGroup = document.getElementById(`rep-group-${dia}-${ex}`);
            const tempoGroup = document.getElementById(`tempo-group-${dia}-${ex}`);

            if (tipo == '1') { // Tempo
                if (repGroup) repGroup.style.display = 'none';
                if (tempoGroup) tempoGroup.style.display = '';
            } else { // Repetições (padrão)
                if (repGroup) repGroup.style.display = '';
                if (tempoGroup) tempoGroup.style.display = 'none';
            }
        });

        // Trigger inicial
        sel.dispatchEvent(new Event('change'));
    });
</script>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}