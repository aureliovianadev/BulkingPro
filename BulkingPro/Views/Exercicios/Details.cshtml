@model BulkingPro.Models.Exercicio
@{
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    ViewData["Title"]      = "Detalhes do Exercício";
    ViewData["ActivePage"] = "Exercicios";
}

@section Topbar {
    <div class="topbar">
        <div>
            <div class="topbar-title">@Model.Nome</div>
            <div class="topbar-sub">Detalhes do exercício</div>
        </div>
        <div class="topbar-actions">
            <a class="btn btn-ghost" asp-action="Edit" asp-route-id="@Model.Id">
                <i class="ti ti-edit"></i> Editar
            </a>
            <a class="btn btn-ghost" asp-action="Index">
                <i class="ti ti-arrow-left"></i> Voltar
            </a>
        </div>
    </div>
}

<div style="max-width:600px;display:flex;flex-direction:column;gap:14px">

    <!-- Identificação -->
    <div class="card">
        <div class="card-body">
            <div class="detail-row">
                <div class="detail-item">
                    <div class="detail-label">Nome</div>
                    <div class="detail-value">@Model.Nome</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Grupo Muscular</div>
                    <div class="detail-value">@(Model.GrupoMuscular?.Nome ?? "—")</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Categoria</div>
                    <div class="detail-value">@(Model.GrupoMuscular?.CategoriaMuscular?.Nome ?? "—")</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Status</div>
                    <div class="detail-value">
                        @if (Model.Ativo)
                        {
                            <span class="badge badge-active">Ativo</span>
                        }
                        else
                        {
                            <span class="badge badge-inactive">Inativo</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Descrição -->
    @if (!string.IsNullOrWhiteSpace(Model.Descricao))
    {
        <div class="card">
            <div class="card-body">
                <div class="detail-label" style="margin-bottom:10px">Descrição</div>
                <p class="detail-text">@Model.Descricao</p>
            </div>
        </div>
    }

    <!-- Instruções -->
    @if (!string.IsNullOrWhiteSpace(Model.InstrucoesExecucao))
    {
        <div class="card">
            <div class="card-body">
                <div class="detail-label" style="margin-bottom:10px">Instruções de execução</div>
                <p class="detail-text">@Model.InstrucoesExecucao</p>
            </div>
        </div>
    }

    <!-- Datas -->
    <div class="card">
        <div class="card-body">
            <div class="detail-row">
                <div class="detail-item">
                    <div class="detail-label">Cadastrado em</div>
                    <div class="detail-value">@Model.DataCriacao.ToString("dd/MM/yyyy")</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Última atualização</div>
                    <div class="detail-value">
                        @(Model.DataAtualizacao.HasValue
                            ? Model.DataAtualizacao.Value.ToString("dd/MM/yyyy")
                            : "—")
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Ações -->
    <div style="display:flex;gap:10px">
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">
            <i class="ti ti-edit"></i> Editar
        </a>
        <a class="btn btn-danger" asp-action="Delete" asp-route-id="@Model.Id">
            <i class="ti ti-trash"></i> Excluir
        </a>
    </div>
</div>

<style>
    .detail-row   { display: flex; flex-wrap: wrap; gap: 20px; }
    .detail-item  { flex: 1; min-width: 120px; }
    .detail-label { font-size: 10px; color: rgba(255,255,255,0.3); letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 5px; }
    .detail-value { font-size: 14px; color: rgba(255,255,255,0.85); font-weight: 500; }
    .detail-text  { font-size: 13px; color: rgba(255,255,255,0.55); line-height: 1.7; }
</style>
